#!/usr/bin/env bash
set -euo pipefail

# The tool always resolves the parent repo from $PWD; ambient git env
# vars (from wrapper scripts, hooks, prompts) would silently redirect
# every git call below.
unset GIT_DIR GIT_WORK_TREE GIT_COMMON_DIR GIT_INDEX_FILE

# git-nook — real git for a directory your host repo won't track.
#
# A nook is an ordinary git repository whose git-dir hides under the parent
# repo's .git/ and whose worktree is a content dir the parent excludes.
# 'add' creates and wires one; every other operation is plain git run
# against it through the passthrough:
#
#   git nook add <name> <target> [--dir <d>] [--ref <tpl>]
#   git nook list | materialize
#   git nook -n <name> show | remove | run <any-git-args...>
#
# Design: docs/plans/2026-07-05-git-nook-design.md

# VERSION is replaced at build/install time; the VERSION file is the source of truth.
VERSION="v0.0.0-dev"

DEFAULT_REF_TEMPLATE='refs/nook/<owner>/<project>/<name>'

usage() {
    cat <<EOF
git-nook ${VERSION} — real git for a directory your host repo won't track

Usage:
  git nook add <name> <target-url-or-remote> [--dir <dir>] [--ref <template>]
  git nook list
  git nook materialize             # link configured nooks into this worktree
  git nook -n <name> show
  git nook -n <name> remove
  git nook -n <name> run <git-args...>   # run any git command against the nook
  git nook --help | --version

A nook is a real git repository, invisible to this repo's own git commands:
its git-dir lives inside this repo's .git directory, and its worktree is a
content dir this repo excludes. 'add' wires its remote to a custom ref
(default: ${DEFAULT_REF_TEMPLATE}), so push/pull/status work out of the box:

  git nook -n notes run status
  git nook -n notes run add --all
  git nook -n notes run commit -m "something"
  git nook -n notes run push
EOF
}

err() { echo "git-nook: error: $*" >&2; }

# Map every character outside [A-Za-z0-9] to '_'. Used to build the slug's
# field values for ref/dir/config names. Lossy on purpose: exact values live
# in the manifest. bash-3.2 safe (tr, not ${//} class tricks).
sanitize_field() {
    printf '%s' "$1" | LC_ALL=C tr -c 'A-Za-z0-9' '_' 2>/dev/null | LC_ALL=C tr -d '\n'
}

# Generate a lowercase UUID-ish identity string. Prefers uuidgen; falls back
# to the kernel RNG, then to a hash of host+pid+time+RANDOM. bash-3.2 safe.
# Output is lowercased and stripped of any non-hex/dash so id3 stays clean.
gen_uuid() {
    local raw=""
    if command -v uuidgen >/dev/null 2>&1; then
        raw=$(uuidgen 2>/dev/null)
    fi
    if [[ -z "${raw}" ]] && [[ -r /proc/sys/kernel/random/uuid ]]; then
        raw=$(cat /proc/sys/kernel/random/uuid 2>/dev/null)
    fi
    if [[ -z "${raw}" ]]; then
        # Portable last resort: hash entropy sources. git is always present.
        raw=$(printf '%s-%s-%s-%s' "$(hostname 2>/dev/null)" "$$" \
              "$(date +%s 2>/dev/null)" "${RANDOM}${RANDOM}${RANDOM}" \
              | git hash-object --stdin 2>/dev/null)
    fi
    printf '%s' "${raw}" | LC_ALL=C tr '[:upper:]' '[:lower:]' | LC_ALL=C tr -cd 'a-f0-9'
}

# Build the canonical slug from (name, full-uuid, owner, repo_dir). Each field
# is sanitized; id3 = first 3 chars of the uuid (already lowercase hex from
# gen_uuid). The slug is used identically for local dirs, config, and refs.
build_slug() {
    local name="$1" uuid="$2" owner="$3" repo="$4" id3
    id3=$(printf '%s' "${uuid}" | cut -c1-3)
    printf '%s.%s.%s.%s' \
        "$(sanitize_field "${name}")" \
        "$(sanitize_field "${id3}")" \
        "$(sanitize_field "${owner}")" \
        "$(sanitize_field "${repo}")"
}

require_work_tree() {
    # Inside a bare repo, `--is-inside-work-tree` prints "false" but still
    # EXITS 0, so a plain `if ! git ...` guard would not fire. Compare the
    # printed value, and treat any nonzero exit (not a repo at all) as failure.
    local inside
    if ! inside=$(git rev-parse --is-inside-work-tree 2>/dev/null) \
       || [[ "${inside}" != "true" ]]; then
        err "not inside a git repository work tree"
        exit 1
    fi
}

# Looser than require_work_tree: succeeds anywhere git can resolve a repo,
# INCLUDING physically inside a .git dir. The passthrough dispatch needs this
# because a materialized nook's content path is a symlink into the nested
# work-tree under the parent's .git/, so `cd`-ing into a nook lands cwd inside
# .git — where --is-inside-work-tree prints "false" but run_passthrough still
# works (it only needs common_git_dir). Rejecting that would break passthrough.
require_git_repo() {
    if ! git rev-parse --git-dir >/dev/null 2>&1; then
        err "not inside a git repository"
        exit 1
    fi
}

# cd to the enclosing work tree's toplevel, surfacing failure explicitly.
# `cd "$(git rev-parse --show-toplevel)"` would NOT abort under `set -e` when
# rev-parse fails: the substitution collapses to "", so the command becomes a
# `cd ""` no-op that exits 0. The two-step form below actually catches it.
cd_to_toplevel() {
    local toplevel
    if ! toplevel=$(git rev-parse --show-toplevel 2>/dev/null); then
        err "not inside a git repository work tree"
        exit 1
    fi
    cd "${toplevel}"
}

# Config is keyed by SLUG: nook.<slug>.dir
channel_dir() { local slug="$1"; git config --get "nook.${slug}.dir"; }

# List all configured slugs (one per line). Keyed by nook.<slug>.dir.
all_slugs() {
    local key
    while read -r key _; do
        [[ -n "${key}" ]] || continue
        key="${key#nook.}"; key="${key%.dir}"
        printf '%s\n' "${key}"
    done < <(git config --get-regexp '^nook\..*\.dir$' 2>/dev/null || true)
}

# Resolve a user-supplied partial to exactly one configured slug by minimal
# left-anchored prefix. Prints the full slug on success. On zero matches:
# error + return 1. On multiple: error listing candidates + return 1.
resolve_slug_prefix() {
    local partial="$1" s matches=""
    while read -r s; do
        [[ -n "${s}" ]] || continue
        # Exact match wins immediately.
        if [[ "${s}" == "${partial}" ]]; then
            printf '%s\n' "${s}"
            return 0
        fi
        if [[ "${s}" == "${partial}"* ]]; then
            matches="${matches}${s}"$'\n'
        fi
    done < <(all_slugs)
    matches="${matches%$'\n'}"
    if [[ -z "${matches}" ]]; then
        err "no nook matches '${partial}' (see: git nook list)"
        return 1
    fi
    if [[ "$(printf '%s\n' "${matches}" | wc -l | tr -d ' ')" -gt 1 ]]; then
        err "'${partial}' is ambiguous; matches:"
        printf '%s\n' "${matches}" | while read -r s; do
            [[ -n "${s}" ]] && err "  ${s}"
        done
        return 1
    fi
    printf '%s\n' "${matches}"
}

# Absolute path of the parent's common git dir (worktree-safe; portable
# normalization because --git-common-dir may print a relative path).
# All wrapper commands cd to the parent toplevel first, so relative is safe
# to resolve against $PWD.
common_git_dir() {
    local out
    out=$(git rev-parse --git-common-dir)
    case "${out}" in
        /*) printf '%s\n' "${out}" ;;
        *)  printf '%s/%s\n' "$(pwd)" "${out}" ;;
    esac
}

# Absolute path of the inner git dir for a nook, keyed by SLUG.
inner_git_dir() { printf '%s/nook/%s.git\n' "$(common_git_dir)" "$1"; }

# Absolute path of the CONTAINER dir for a nook: git-nook owns this (creates
# it on add, removes it on rollback). Lives in the common git dir so every
# worktree shares it. Independent of the configured content dir. Keyed by SLUG.
canonical_container() { printf '%s/nook/%s.nook\n' "$(common_git_dir)" "$1"; }

# Absolute path of a nook's WORK-TREE: the content dir nested inside the
# container, named for the basename of the configured content dir. This is
# what the per-worktree symlink targets and what `git --work-tree` uses, so
# tracked paths stay bare (the worktree root IS the content dir) and a
# slug-sensitive tool resolving the symlink lands on a dir named basename(dir).
# Falls back to the container itself only if the dir config is somehow unset.
# Keyed by SLUG.
canonical_worktree() {
    local slug="$1" dir base
    dir=$(channel_dir "${slug}" 2>/dev/null) || dir=""
    dir="${dir%/}"
    base="${dir##*/}"
    if [[ -n "${base}" ]]; then
        printf '%s/%s\n' "$(canonical_container "${slug}")" "${base}"
    else
        canonical_container "${slug}"
    fi
}

# JSON-escape a scalar string value (quotes, backslashes, control chars).
# bash-3.2 safe; handles the characters that appear in URLs/names/emails.
json_escape() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\t'/\\t}"
    s="${s//$'\r'/\\r}"
    printf '%s' "${s}"
}

# Build manifest.json content from fields. Its own function so tests and
# reindex can reuse it.
manifest_json() {
    local uuid="$1" name="$2" owner="$3" repo="$4" upstream="$5" user="$6" at="$7"
    cat <<EOF
{
  "uuid": "$(json_escape "${uuid}")",
  "name": "$(json_escape "${name}")",
  "created": {
    "owner": "$(json_escape "${owner}")",
    "repo_dir": "$(json_escape "${repo}")",
    "upstream": "$(json_escape "${upstream}")",
    "user": "$(json_escape "${user}")",
    "at": "$(json_escape "${at}")"
  }
}
EOF
}

# Write manifest.json into a one-file tree and commit it to
# refs/nook-meta/manifest in the inner repo (never on refs/heads/main).
write_manifest_ref() {
    local gd="$1" uuid="$2" name="$3" owner="$4" repo="$5" upstream="$6" user="$7" at="$8"
    local blob tree commit
    blob=$(manifest_json "${uuid}" "${name}" "${owner}" "${repo}" "${upstream}" "${user}" "${at}" \
        | git --git-dir="${gd}" hash-object -w --stdin)
    tree=$(printf '100644 blob %s\tmanifest.json\n' "${blob}" \
        | git --git-dir="${gd}" mktree)
    commit=$(printf 'nook manifest\n' \
        | git --git-dir="${gd}" commit-tree "${tree}")
    git --git-dir="${gd}" update-ref refs/nook-meta/manifest "${commit}"
}

# Read a top-level string field (uuid|name) or created.<field>
# (owner|repo_dir|upstream|user|at) from the manifest.json committed at <ref>
# in the inner repo. The manifest shape is fixed and machine-written, so a
# line grep is safe.
read_manifest_field() {
    local gd="$1" ref="$2" field="$3" line
    line=$(git --git-dir="${gd}" show "${ref}:manifest.json" 2>/dev/null \
        | grep -E "\"${field}\"[[:space:]]*:" | head -n1) || return 1
    printf '%s' "${line}" | sed -E 's/.*: *"(.*)".*/\1/'
}

# Prints "<owner>\t<project>" derived from the origin remote URL, falling
# back to owner=local, project=<toplevel dirname> when there is no origin.
owner_and_project() {
    local url path owner project
    if url=$(git remote get-url origin 2>/dev/null); then
        case "${url}" in
            *://*) path="${url#*://}" ;;            # scheme://host/owner/repo
            *:*)   path="${url%%:*}/${url#*:}" ;;   # host:owner/repo (scp-like)
            *)     path="${url}" ;;                 # plain filesystem path
        esac
        path="${path%/}"
        path="${path%.git}"
        project=$(basename "${path}")
        owner=$(basename "$(dirname "${path}")")
        if [[ -z "${owner}" || "${owner}" == "." || "${owner}" == "/" ]]; then
            owner="local"
        fi
    else
        # Reached only after a caller has cd'd into the work tree's toplevel
        # (require_work_tree + cd_to_toplevel), so rev-parse cannot fail here.
        # shellcheck disable=SC2312 # nested substitution; toplevel is known-valid
        project=$(basename "$(git rev-parse --show-toplevel)")
        owner="local"
    fi
    printf '%s\t%s\n' "${owner}" "${project}"
}

# Resolve a ref template (<owner>/<project>/<name> tokens). A resolved value
# starting with refs/ is used verbatim; anything else goes under refs/heads/.
resolve_ref() {
    local tpl="$1" name="$2" owner project
    IFS=$'\t' read -r owner project < <(owner_and_project)
    tpl="${tpl//<owner>/${owner}}"
    tpl="${tpl//<project>/${project}}"
    tpl="${tpl//<name>/${name}}"
    [[ "${tpl}" == refs/* ]] || tpl="refs/heads/${tpl}"
    if ! git check-ref-format "${tpl}" >/dev/null 2>&1; then
        err "resolved ref '${tpl}' is not a valid git ref (check --ref and your origin URL)"
        return 1
    fi
    printf '%s\n' "${tpl}"
}

# STUB until the index task: no-op index update. Returns 0.
index_add_entry() { return 0; }

validate_name() {
    local name="$1"
    if [[ "${name}" == -* || "${name}" == */* ]] \
        || ! git check-ref-format "refs/nook/${name}" >/dev/null 2>&1; then
        err "'${name}' is not a valid nook name (one path component, no leading '-')"
        return 1
    fi
}

# Absolute info/exclude path, worktree-safe (resolved after cd to toplevel).
exclude_file() {
    local out
    out=$(git rev-parse --git-path info/exclude)
    case "${out}" in
        /*) printf '%s\n' "${out}" ;;
        *)  printf '%s/%s\n' "$(pwd)" "${out}" ;;
    esac
}

add_exclude_entry() {
    local entry="$1" file
    file=$(exclude_file)
    mkdir -p "$(dirname "${file}")"
    if ! grep -qxF "${entry}" "${file}" 2>/dev/null; then
        # shellcheck disable=SC2312 # tail failure worst case adds a blank line
        if [[ -s "${file}" ]] && [[ "$(tail -c 1 "${file}")" != "" ]]; then
            printf '\n' >> "${file}"
        fi
        printf '%s\n' "${entry}" >> "${file}"
    fi
}

# Remove a nook's info/exclude entry (both the historical trailing-slash form
# and the current no-slash form that covers the symlink).
# Takes a bare dir (no leading slash) — unlike add_exclude_entry, which takes the full entry string.
# Consumed by bootstrap rollback (cmd_add) and by cmd_remove.
remove_exclude_entry() {
    local dir="$1" file tmp
    file=$(exclude_file)
    [[ -f "${file}" ]] || return 0
    tmp=$(mktemp)
    grep -vxF "/${dir}" "${file}" | grep -vxF "/${dir}/" > "${tmp}" || true
    mv "${tmp}" "${file}"
}

# Populate a nook's nested work-tree from the inner repo's committed HEAD.
# Used only when the work-tree is the source of truth (absent / correct-symlink
# / empty-real-dir cases) -- NEVER before migrating a legacy real dir, whose
# on-disk files are themselves the authoritative content. Unborn/empty HEAD is
# a clean no-op (leave the work-tree empty). Returns 1 on a real checkout error.
populate_checkout_from_head() {
    local gitdir="$1" checkout_dir="$2"
    if git --git-dir="${gitdir}" rev-parse --verify -q HEAD >/dev/null 2>&1; then
        if ! git --git-dir="${gitdir}" --work-tree="${checkout_dir}" checkout -- .; then
            err "could not populate the nook checkout at ${checkout_dir}"
            return 1
        fi
    fi
}

# Ensure a single nook is correctly materialized in the CURRENT worktree: the
# nook's nested work-tree exists, and the configured path is a symlink to it
# (migrating an old real dir, or an old flat container layout, if present).
# Callers must already have cd'd to the parent repo toplevel.
materialize_one() {
    local name="$1" toplevel dir container_dir checkout_dir gitdir content_path t checkout_real c_has d_has migrated_now=0 repoint_only=0
    toplevel=$(git rev-parse --show-toplevel)
    dir=$(channel_dir "${name}")               # configured path, verbatim (may start with '.')
    container_dir=$(canonical_container "${name}")   # git-nook-owned container dir
    checkout_dir=$(canonical_worktree "${name}")     # nested content dir (the work-tree)
    gitdir=$(inner_git_dir "${name}")
    content_path="${toplevel}/${dir}"

    # MIGRATION: an old flat layout has tracked files directly in the container
    # and a symlink pointing at the container (not the nested work-tree). Detect
    # by the symlink's resolved target, never by content names. Move the flat
    # files down into the nested work-tree, then repoint the symlink directly
    # (the migrated content is already authoritative -- see below).
    #
    # Detection must run BEFORE the nested work-tree dir is created: if it were
    # created first, a tracked container entry that happens to be named
    # basename(dir) would be indistinguishable from the just-created work-tree
    # dir, and the "skip the work-tree we just made" check below would wrongly
    # skip that tracked entry (or collide with it). So migration stages every
    # container entry into a throwaway staging dir FIRST (a staging name
    # reserved by git-nook, assumed absent from tracked content), and only
    # then creates the nested work-tree and moves the staged entries into it.
    #
    # A symlink resolving to the container is "old flat layout" ONLY if the
    # container isn't ALREADY migrated. Migration state (the container) is
    # shared across worktrees, but the per-worktree symlink is not: a second
    # worktree can still have a stale symlink -> container after worktree A
    # already migrated it. Distinguish by whether the container's ONLY
    # meaningful entry (ignoring the transient stage dir) is the work-tree
    # dir itself: a genuinely-flat container's entries are the tracked
    # files/dirs directly, so even when one happens to collide in name with
    # basename(dir) (see the collision test) there is at least one OTHER
    # entry alongside it; an already-migrated container has nothing else --
    # the work-tree dir is the sole entry. The entry scan itself ignores the
    # transient stage dir's NAME (it must not count as an "other entry" that
    # would defeat an otherwise-genuine already-migrated match), but a
    # non-empty stage dir means a prior migration was interrupted mid-run,
    # not that we are already migrated -- resumed below (the migration path's
    # second loop sweeps the stage into the work-tree), never repointed. An
    # empty/absent work-tree with no stage is the other case that resumes.
    if [[ -L "${content_path}" ]]; then
        t=$(cd "${content_path}" 2>/dev/null && pwd -P) || t=""
        if [[ -n "${t}" && "${t}" == "$(cd "${container_dir}" && pwd -P)" ]]; then
            local stage_probe="${container_dir}/.git-nook-migrate" only_entry=1
            if [[ -d "${checkout_dir}" ]] && [[ -n "$(ls -A "${checkout_dir}" 2>/dev/null)" ]]; then
                ( shopt -s dotglob nullglob
                  for e in "${container_dir}"/*; do
                      [[ "${e}" == "${stage_probe}" ]] && continue
                      [[ "${e}" == "${checkout_dir}" ]] && continue
                      exit 1
                  done ) || only_entry=0
            else
                only_entry=0
            fi
            # A populated staging dir means a prior migration was interrupted,
            # not that we are already migrated -> resume (loop 2 below sweeps
            # the stage into the work-tree), never repoint-only.
            if [[ -d "${stage_probe}" ]] && [[ -n "$(ls -A "${stage_probe}" 2>/dev/null)" ]]; then
                only_entry=0
            fi
            if [[ "${only_entry}" -eq 1 ]]; then
                # Already migrated behind a stale symlink -> container: just
                # repoint below, do NOT re-migrate (would double-nest) and do
                # NOT populate from HEAD (the work-tree already holds the
                # authoritative content, possibly with uncommitted edits).
                rm -f "${content_path}"
                repoint_only=1
            else
                # symlink still points at the container -> old flat layout (or
                # an interrupted migration to resume).
                local stage="${container_dir}/.git-nook-migrate"
                # Non-destructive: a prior interrupted migration may have left staged
                # entries here (possibly uncommitted/untracked content, e.g. an edited
                # issues.jsonl). Never rm -rf this dir -- leftovers are simply
                # re-migrated by the loop below on this run.
                mkdir -p "${stage}" || { err "could not stage migration for '${name}'"; return 1; }
                ( shopt -s dotglob nullglob
                  for e in "${container_dir}"/*; do
                      [[ "${e}" == "${stage}" ]] && continue
                      mv "${e}" "${stage}/" || { err "failed to stage '${e}' during migration"; exit 1; }
                  done ) || { err "migration staging left content in '${stage}'; resolve manually and re-run: git nook materialize"; return 1; }
                mkdir -p "${checkout_dir}" || { err "could not create the nook work-tree at ${checkout_dir}"; return 1; }
                # If interrupted mid-loop here, a re-run re-stages the (possibly
                # half-populated) work-tree via the container-scan above -- data is
                # never destroyed, but an interruption mid-move may leave a nested
                # dir to un-nest by hand (not just another materialize).
                ( shopt -s dotglob nullglob
                  for e in "${stage}"/*; do
                      mv "${e}" "${checkout_dir}/" || { err "failed to migrate '${e}' into '${checkout_dir}'"; exit 1; }
                  done ) || return 1
                rmdir "${stage}" || { err "could not remove migration staging dir '${stage}'"; return 1; }
                rm -f "${content_path}"   # drop the stale symlink; re-created below
                migrated_now=1
            fi
        fi
    fi

    # Ensure the nested work-tree dir exists (empty for now). Already created
    # above when a flat-layout migration ran; this is a no-op in that case and
    # covers every other path (fresh add, correct symlink, absent).
    mkdir -p "${checkout_dir}" || { err "could not create the nook work-tree at ${checkout_dir}"; return 1; }

    # A real flat->nested migration just moved the user's live (possibly
    # uncommitted) content into the work-tree. That content is ALREADY
    # authoritative -- repoint the symlink directly and return WITHOUT ever
    # calling populate_checkout_from_head, which would force-checkout HEAD and
    # clobber any uncommitted edits to tracked files.
    # Likewise, repointing a stale symlink at an already-migrated container
    # must never populate from HEAD -- same reasoning, the work-tree content
    # is already authoritative.
    if [[ "${migrated_now}" -eq 1 || "${repoint_only}" -eq 1 ]]; then
        mkdir -p "$(dirname "${content_path}")"
        ln -s "${checkout_dir}" "${content_path}"
        add_exclude_entry "/${dir}"
        echo "git-nook: materialized ${name} -> ${dir}"
        return 0
    fi

    # Reconcile the per-worktree path content_path against the work-tree.
    if [[ -L "${content_path}" ]]; then
        # existing symlink: OK only if it already points at the work-tree
        t=$(cd "${content_path}" 2>/dev/null && pwd -P) || t=""
        checkout_real=$(cd "${checkout_dir}" && pwd -P)
        if [[ "${t}" != "${checkout_real}" ]]; then
            err "'${dir}' is a symlink to '${t}', not the nook work-tree '${checkout_dir}'; refusing to clobber"
            return 1
        fi
        # shellcheck disable=SC2310 # failure handled by the || return
        populate_checkout_from_head "${gitdir}" "${checkout_dir}" || return 1
    elif [[ -d "${content_path}" ]]; then
        d_has=$(ls -A "${content_path}" 2>/dev/null)
        c_has=$(ls -A "${checkout_dir}" 2>/dev/null)
        if [[ -n "${d_has}" ]]; then
            if [[ -n "${c_has}" ]]; then
                err "both '${dir}' and the nook work-tree '${checkout_dir}' have content; reconcile manually"
                return 1
            fi
        else
            # shellcheck disable=SC2310 # failure handled by the || return
            populate_checkout_from_head "${gitdir}" "${checkout_dir}" || return 1
        fi
        ( shopt -s dotglob nullglob; for e in "${content_path}"/*; do mv "${e}" "${checkout_dir}/" || { err "failed to move '${e}' into '${checkout_dir}'"; exit 1; }; done )
        rmdir "${content_path}" || { err "could not remove '${dir}' after migrating its contents"; return 1; }
        mkdir -p "$(dirname "${content_path}")"
        ln -s "${checkout_dir}" "${content_path}"
    elif [[ -e "${content_path}" ]]; then
        err "'${dir}' exists but is not a directory or symlink"
        return 1
    else
        # shellcheck disable=SC2310 # failure handled by the || return
        populate_checkout_from_head "${gitdir}" "${checkout_dir}" || return 1
        mkdir -p "$(dirname "${content_path}")"
        ln -s "${checkout_dir}" "${content_path}"
    fi

    add_exclude_entry "/${dir}"

    echo "git-nook: materialized ${name} -> ${dir}"
    return 0
}

# Roll back a partially-created nook (used by cmd_add on bootstrap/materialize
# failure) so a retry starts clean. remove_exclude_entry strips both exclude
# forms in one call, regardless of which stage failed.
rollback_add() {
    local name="$1" dir="$2" toplevel="$3" gitdir="$4" container_dir="$5" made_link="$6" made_ckout="$7"
    rm -rf "${gitdir}"
    git config --remove-section "nook.${name}" 2>/dev/null || true
    remove_exclude_entry "${dir}"
    [[ -n "${made_link}" ]] && rm -f "${toplevel}/${dir}"
    [[ -n "${made_ckout}" ]] && rm -rf "${container_dir}"
    : # ensure exit status 0 so the trailing [[ ]] && cmd never trips set -e
}

# --- Subcommands ------------------------------------------------------------------

cmd_init() {
    require_work_tree
    cd_to_toplevel
    local toplevel; toplevel=$(pwd)

    local name="" target="" dir=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dir)
                [[ $# -ge 2 ]] || { err "--dir requires a value"; exit 1; }
                dir="$2"; shift 2 ;;
            -*) err "unknown init option '$1'"; exit 1 ;;
            *)
                if [[ -z "${name}" ]]; then name="$1"
                elif [[ -z "${target}" ]]; then target="$1"
                else err "unexpected extra argument '$1'"; exit 1; fi
                shift ;;
        esac
    done
    if [[ -z "${name}" || -z "${target}" ]]; then
        err "usage: git nook init <name> <target-url-or-remote> [--dir <d>]"
        exit 1
    fi
    validate_name "${name}" || exit 1

    local url
    if url=$(git remote get-url "${target}" 2>/dev/null); then :
    elif [[ "${target}" == *[:/]* ]]; then url="${target}"
    else err "'${target}' is not a remote in this repo (and doesn't look like a URL)"; exit 1; fi

    local owner project uuid slug
    IFS=$'\t' read -r owner project < <(owner_and_project)
    uuid=$(gen_uuid)
    slug=$(build_slug "${name}" "${uuid}" "${owner}" "${project}")

    if channel_dir "${slug}" >/dev/null 2>&1; then
        err "nook '${slug}' already exists (see: git nook -n ${slug} show)"; exit 1
    fi
    local existing existing_lc slug_lc
    slug_lc=$(printf '%s' "${slug}" | tr '[:upper:]' '[:lower:]')
    while read -r existing; do
        [[ -n "${existing}" ]] || continue
        existing_lc=$(printf '%s' "${existing}" | tr '[:upper:]' '[:lower:]')
        if [[ "${existing_lc}" == "${slug_lc}" ]]; then
            err "nook '${existing}' already exists and differs only by case (unsafe on case-insensitive filesystems)"; exit 1
        fi
    done < <(all_slugs)

    [[ -n "${dir}" ]] || dir="${name}"
    dir="${dir%/}"
    case "${dir}" in
        /* | . | .. | ./* | ../* | */.. | */../* | .git | .git/* | */.git | */.git/*)
            err "--dir must be a repo-relative path (no '..', not under .git)"; exit 1 ;;
    esac
    if [[ -n "$(git ls-files -- "${dir}" 2>/dev/null)" ]]; then
        err "'${dir}/' contains files tracked by this repository; pick an untracked dir"; exit 1
    fi
    local key other_dir other_slug
    while read -r key other_dir; do
        [[ -n "${key}" ]] || continue
        other_slug="${key#nook.}"; other_slug="${other_slug%.dir}"
        if [[ "${dir}/" == "${other_dir}/"* || "${other_dir}/" == "${dir}/"* ]]; then
            err "'${dir}/' overlaps nook '${other_slug}' (${other_dir}/)"; exit 1
        fi
    done < <(git config --get-regexp '^nook\..*\.dir$' 2>/dev/null || true)

    local files_ref meta_ref gitdir checkout_dir container_dir
    files_ref="refs/nook/${slug}/files"
    meta_ref="refs/nook/${slug}/manifest"
    gitdir=$(inner_git_dir "${slug}")
    if [[ -e "${gitdir}" ]]; then
        err "an inner repo already exists at ${gitdir}"; exit 1
    fi
    if [[ -e "${dir}" || -L "${dir}" ]] && [[ ! -d "${dir}" ]]; then
        err "'${dir}' exists but is not a directory"; exit 1
    fi

    local made_ckout="" made_link=""
    mkdir -p "$(dirname "${gitdir}")"
    git init --quiet --bare "${gitdir}"
    git --git-dir="${gitdir}" symbolic-ref HEAD refs/heads/main
    git --git-dir="${gitdir}" config core.bare false
    git --git-dir="${gitdir}" config core.autocrlf false
    git --git-dir="${gitdir}" config remote.origin.url "${url}"
    git --git-dir="${gitdir}" config remote.origin.fetch "+${files_ref}:refs/remotes/origin/main"
    git --git-dir="${gitdir}" config remote.origin.push "refs/nook-meta/manifest:${meta_ref}"
    git --git-dir="${gitdir}" config --add remote.origin.push "refs/heads/main:${files_ref}"
    git --git-dir="${gitdir}" config branch.main.remote origin
    git --git-dir="${gitdir}" config branch.main.merge "${files_ref}"

    git config "nook.${slug}.dir" "${dir}"
    checkout_dir=$(canonical_worktree "${slug}")
    container_dir=$(canonical_container "${slug}")

    local host_origin user_ident now uname uemail
    host_origin=$(git remote get-url origin 2>/dev/null || printf '')
    uname=$(git config user.name 2>/dev/null || printf '')
    uemail=$(git config user.email 2>/dev/null || printf '')
    user_ident="${uname} <${uemail}>"
    now=$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date +%Y-%m-%dT%H:%M:%SZ)
    write_manifest_ref "${gitdir}" "${uuid}" "${name}" "${owner}" "${project}" "${host_origin}" "${user_ident}" "${now}"

    echo "git-nook: initialized nook '${name}' as ${slug} (dir ${dir}/, target ${url})"

    [[ -n "$(ls -A "${container_dir}" 2>/dev/null)" ]] || made_ckout=1
    if ! materialize_one "${slug}"; then
        rollback_add "${slug}" "${dir}" "${toplevel}" "${gitdir}" "${container_dir}" "${made_link}" "${made_ckout}"
        err "materializing ${slug} failed; rolled back"; exit 1
    fi
    made_link=1

    # main is unborn at init (no commits yet), so a combined push with the
    # files refspec would fail atomically on the unmatched src -- and take
    # the manifest push down with it. Publish only the manifest here; the
    # files refspec (still on remote.origin.push, set above) publishes once
    # the user's first commit + a bare `run push` gives main something to push.
    if git --git-dir="${gitdir}" push --quiet origin \
         "refs/nook-meta/manifest:${meta_ref}" 2>/dev/null; then
        index_add_entry "${gitdir}" "${url}" "${slug}" || \
          echo "git-nook: warning: index update failed; run: git nook reindex" >&2
    else
        echo "git-nook: note: could not publish manifest to ${url} yet; it will publish on your first: git nook -n ${slug} run push" >&2
    fi
}

# List candidate slugs on a remote matching <name>, via ls-remote on the
# content refs. Prints matching slugs (one per line).
remote_slugs_for_name() {
    local url="$1" name="$2" ref slug
    git ls-remote "${url}" 'refs/nook/*/files' 2>/dev/null | while read -r _ ref; do
        slug="${ref#refs/nook/}"; slug="${slug%/files}"
        case "${slug}" in
            "${name}".*) printf '%s\n' "${slug}" ;;
        esac
    done
}

cmd_clone() {
    require_work_tree
    cd_to_toplevel
    local toplevel; toplevel=$(pwd)

    local name="" target="" dir=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dir) [[ $# -ge 2 ]] || { err "--dir requires a value"; exit 1; }; dir="$2"; shift 2 ;;
            -*) err "unknown clone option '$1'"; exit 1 ;;
            *) if [[ -z "${name}" ]]; then name="$1"
               elif [[ -z "${target}" ]]; then target="$1"
               else err "unexpected extra argument '$1'"; exit 1; fi; shift ;;
        esac
    done
    [[ -n "${name}" && -n "${target}" ]] || { err "usage: git nook clone <name> <target-url-or-remote> [--dir <d>]"; exit 1; }

    local url
    if url=$(git remote get-url "${target}" 2>/dev/null); then :
    elif [[ "${target}" == *[:/]* ]]; then url="${target}"
    else err "'${target}' is not a remote in this repo (and doesn't look like a URL)"; exit 1; fi

    local candidates chosen count
    candidates=$(remote_slugs_for_name "${url}" "${name}")
    candidates=$(printf '%s\n' "${candidates}" | grep -v '^$' || true)
    count=$(printf '%s\n' "${candidates}" | grep -c '.' || true)
    if [[ "${count}" -eq 0 ]]; then
        err "no nook named '${name}' found at ${url}; create one with: git nook init ${name} ${target}"; exit 1
    elif [[ "${count}" -eq 1 ]]; then
        chosen="${candidates}"
    else
        echo "Multiple nooks named '${name}' at ${url}:" >&2
        local i=0 s
        while read -r s; do
            [[ -n "${s}" ]] || continue
            i=$((i+1)); printf '  %d) %s\n' "${i}" "${s}" >&2
        done < <(printf '%s\n' "${candidates}")
        printf 'Choose [1-%d]: ' "${i}" >&2
        local pick
        if ! read -r pick; then
            err "invalid choice"; exit 1
        fi
        if ! printf '%s' "${pick}" | grep -qE '^[0-9]+$' || [[ "${pick}" -lt 1 || "${pick}" -gt "${i}" ]]; then
            err "invalid choice"; exit 1
        fi
        chosen=$(printf '%s\n' "${candidates}" | sed -n "${pick}p")
        [[ -n "${chosen}" ]] || { err "invalid choice"; exit 1; }
    fi

    [[ -n "${dir}" ]] || dir="${name}"
    dir="${dir%/}"
    case "${dir}" in
        /* | . | .. | ./* | ../* | */.. | */../* | .git | .git/* | */.git | */.git/*)
            err "--dir must be a repo-relative path (no '..', not under .git)"; exit 1 ;;
    esac
    if [[ -n "$(git ls-files -- "${dir}" 2>/dev/null)" ]]; then
        err "'${dir}/' contains files tracked by this repository; pick an untracked dir"; exit 1
    fi
    local key other_dir other_slug
    while read -r key other_dir; do
        [[ -n "${key}" ]] || continue
        other_slug="${key#nook.}"; other_slug="${other_slug%.dir}"
        if [[ "${dir}/" == "${other_dir}/"* || "${other_dir}/" == "${dir}/"* ]]; then
            err "'${dir}/' overlaps nook '${other_slug}' (${other_dir}/)"; exit 1
        fi
    done < <(git config --get-regexp '^nook\..*\.dir$' 2>/dev/null || true)

    if channel_dir "${chosen}" >/dev/null 2>&1; then
        err "nook '${chosen}' already exists locally"; exit 1
    fi

    local files_ref meta_ref gitdir checkout_dir container_dir made_ckout="" made_link=""
    files_ref="refs/nook/${chosen}/files"
    meta_ref="refs/nook/${chosen}/manifest"
    gitdir=$(inner_git_dir "${chosen}")
    [[ -e "${gitdir}" ]] && { err "an inner repo already exists at ${gitdir}"; exit 1; }

    mkdir -p "$(dirname "${gitdir}")"
    git init --quiet --bare "${gitdir}"
    git --git-dir="${gitdir}" symbolic-ref HEAD refs/heads/main
    git --git-dir="${gitdir}" config core.bare false
    git --git-dir="${gitdir}" config core.autocrlf false
    git --git-dir="${gitdir}" config remote.origin.url "${url}"
    git --git-dir="${gitdir}" config remote.origin.fetch "+${files_ref}:refs/remotes/origin/main"
    git --git-dir="${gitdir}" config remote.origin.push "refs/nook-meta/manifest:${meta_ref}"
    git --git-dir="${gitdir}" config --add remote.origin.push "refs/heads/main:${files_ref}"
    git --git-dir="${gitdir}" config branch.main.remote origin
    git --git-dir="${gitdir}" config branch.main.merge "${files_ref}"

    git config "nook.${chosen}.dir" "${dir}"
    checkout_dir=$(canonical_worktree "${chosen}")
    container_dir=$(canonical_container "${chosen}")

    [[ -n "$(ls -A "${container_dir}" 2>/dev/null)" ]] || made_ckout=1
    # The files ref was proven to exist via ls-remote above, so a fetch
    # failure here is always a real error (network, auth, remote gone
    # since) -- never silently continue into an empty clone.
    if ! git --git-dir="${gitdir}" fetch -q origin; then
        rollback_add "${chosen}" "${dir}" "${toplevel}" "${gitdir}" "${container_dir}" "${made_link}" "${made_ckout}"
        err "clone: could not fetch ${files_ref} from ${url}; rolled back"; exit 1
    fi
    # The manifest ref may legitimately be absent (e.g. not yet published);
    # best-effort only.
    git --git-dir="${gitdir}" fetch -q origin "${meta_ref}:refs/nook-meta/manifest" 2>/dev/null || true

    if git --git-dir="${gitdir}" rev-parse --verify -q refs/remotes/origin/main >/dev/null 2>&1; then
        git --git-dir="${gitdir}" update-ref refs/heads/main refs/remotes/origin/main
        # A plain fetch + update-ref never touches the index (unlike a real
        # `git clone`, which checks out afterward). Seed it from the newly
        # fetched HEAD so materialize_one's populate_checkout_from_head --
        # which does a plain `checkout -- .` against the index, not HEAD --
        # has something to check out instead of failing on an empty index.
        git --git-dir="${gitdir}" read-tree HEAD
    fi
    if ! materialize_one "${chosen}"; then
        rollback_add "${chosen}" "${dir}" "${toplevel}" "${gitdir}" "${container_dir}" "${made_link}" "${made_ckout}"
        err "clone of ${chosen} failed; rolled back"; exit 1
    fi
    echo "git-nook: cloned ${chosen} -> ${dir}/"
}

cmd_add() {
    require_work_tree
    cd_to_toplevel
    local toplevel; toplevel=$(pwd)   # cd_to_toplevel put us at the work-tree root

    local name="" target="" dir="" ref_tpl="${DEFAULT_REF_TEMPLATE}"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dir)
                [[ $# -ge 2 ]] || { err "--dir requires a value"; exit 1; }
                dir="$2"; shift 2 ;;
            --ref)
                [[ $# -ge 2 ]] || { err "--ref requires a value"; exit 1; }
                ref_tpl="$2"; shift 2 ;;
            -*) err "unknown add option '$1'"; exit 1 ;;
            *)
                if [[ -z "${name}" ]]; then name="$1"
                elif [[ -z "${target}" ]]; then target="$1"
                else err "unexpected extra argument '$1'"; exit 1; fi
                shift ;;
        esac
    done
    if [[ -z "${name}" || -z "${target}" ]]; then
        err "usage: git nook add <name> <target-url-or-remote> [--dir <d>] [--ref <tpl>]"
        exit 1
    fi

    validate_name "${name}" || exit 1
    if channel_dir "${name}" >/dev/null 2>&1; then
        err "nook '${name}' already exists (see: git nook -n ${name} show)"
        exit 1
    fi
    # Case-insensitive duplicate check: git config subsections are
    # case-sensitive, but the content dir and the inner git-dir live on a
    # filesystem that may not be. (tr, not ${var,,}: macOS ships bash 3.2.)
    local dup_key dup_name name_lc dup_lc
    name_lc=$(printf '%s' "${name}" | tr '[:upper:]' '[:lower:]')
    while read -r dup_key _; do
        [[ -n "${dup_key}" ]] || continue
        dup_name="${dup_key#nook.}"; dup_name="${dup_name%.dir}"
        dup_lc=$(printf '%s' "${dup_name}" | tr '[:upper:]' '[:lower:]')
        if [[ "${dup_lc}" == "${name_lc}" ]]; then
            err "nook '${dup_name}' already exists and differs from '${name}' only by case (unsafe on case-insensitive filesystems)"
            exit 1
        fi
    done < <(git config --get-regexp '^nook\..*\.dir$' 2>/dev/null || true)

    # Target: an existing parent remote name wins (resolved to its URL once,
    # now); otherwise anything with ':' or '/' is accepted as a literal URL.
    local url
    if url=$(git remote get-url "${target}" 2>/dev/null); then
        :
    elif [[ "${target}" == *[:/]* ]]; then
        url="${target}"
    else
        err "'${target}' is not a remote in this repo (and doesn't look like a URL)"
        exit 1
    fi

    [[ -n "${dir}" ]] || dir="${name}"
    dir="${dir%/}"
    case "${dir}" in
        /* | . | .. | ./* | ../* | */.. | */../* | .git | .git/* | */.git | */.git/*)
            err "--dir must be a repo-relative path (no '..', not under .git)"
            exit 1 ;;
    esac

    # Refusals (design decision 7).
    if [[ -n "$(git ls-files -- "${dir}" 2>/dev/null)" ]]; then
        err "'${dir}/' contains files tracked by this repository; pick an untracked dir"
        exit 1
    fi
    local key other_dir other_name
    while read -r key other_dir; do
        [[ -n "${key}" ]] || continue
        other_name="${key#nook.}"; other_name="${other_name%.dir}"
        if [[ "${dir}/" == "${other_dir}/"* || "${other_dir}/" == "${dir}/"* ]]; then
            err "'${dir}/' overlaps nook '${other_name}' (${other_dir}/)"
            exit 1
        fi
    done < <(git config --get-regexp '^nook\..*\.dir$' 2>/dev/null || true)

    local ref gitdir checkout_dir container_dir
    # shellcheck disable=SC2310 # failure handled by the || exit
    ref=$(resolve_ref "${ref_tpl}" "${name}") || exit 1
    gitdir=$(inner_git_dir "${name}")
    if [[ -e "${gitdir}" ]]; then
        err "an inner repo already exists at ${gitdir}"
        err "it may hold history from a removed nook; delete it first if it is stale: rm -rf '${gitdir}'"
        exit 1
    fi

    # A file, fifo, or dangling symlink at ${dir} would otherwise surface as a
    # raw mkdir error below (-L catches dangling symlinks, which fail -e).
    if [[ -e "${dir}" || -L "${dir}" ]] && [[ ! -d "${dir}" ]]; then
        err "'${dir}' exists but is not a directory"
        exit 1
    fi

    # Bookkeeping for rollback: whether THIS run created the container dir
    # and/or the per-worktree symlink, so a failure can undo exactly what it
    # made and nothing the user already had.
    local made_ckout="" made_link=""

    mkdir -p "$(dirname "${gitdir}")"
    git init --quiet --bare "${gitdir}"
    git --git-dir="${gitdir}" symbolic-ref HEAD refs/heads/main
    git --git-dir="${gitdir}" config core.bare false
    git --git-dir="${gitdir}" config core.autocrlf false
    git --git-dir="${gitdir}" config remote.origin.url "${url}"
    git --git-dir="${gitdir}" config remote.origin.fetch "+${ref}:refs/remotes/origin/main"
    git --git-dir="${gitdir}" config remote.origin.push "refs/heads/main:${ref}"
    git --git-dir="${gitdir}" config branch.main.remote origin
    git --git-dir="${gitdir}" config branch.main.merge "${ref}"

    git config "nook.${name}.dir" "${dir}"
    checkout_dir=$(canonical_worktree "${name}")   # needs nook.<name>.dir, just written above
    container_dir=$(canonical_container "${name}")

    echo "git-nook: added nook '${name}' (dir ${dir}/, target ${url}, ref ${ref})"

    # Materialize as a fresh local nook first (mirrors the old code's eager
    # mkdir -p "${dir}"): this migrates a pre-existing untracked ${dir} into
    # the nook's nested work-tree and symlinks it in, regardless of whether a
    # remote ref turns out to exist below. If a remote ref IS found and is
    # safe to adopt, the bootstrap step below overlays real content on top.
    # made_ckout tracks whether the container had no real content of its own
    # before this add ran (an empty or absent container is not meaningful
    # prior state), so a later failure's rollback can safely rm -rf the whole
    # container.
    [[ -n "$(ls -A "${container_dir}" 2>/dev/null)" ]] || made_ckout=1
    if ! materialize_one "${name}"; then
        rollback_add "${name}" "${dir}" "${toplevel}" "${gitdir}" "${container_dir}" "${made_link}" "${made_ckout}"
        err "materializing ${name} failed; the nook was rolled back — fix the problem above and re-run add"
        exit 1
    fi
    made_link=1

    # Bootstrap when the published ref already exists (never destructive).
    local lsout
    if ! lsout=$(git --git-dir="${gitdir}" ls-remote origin "${ref}" 2>/dev/null); then
        echo "git-nook: warning: could not contact ${url} to check for existing data; if some exists, run: git nook -n ${name} run pull" >&2
        return 0
    fi
    [[ -n "${lsout}" ]] || return 0

    # Would bootstrapping clobber local content? materialize_one above
    # already made ${dir} a symlink to ${checkout_dir}, so checking the
    # nested work-tree's contents covers both.
    if [[ -n "$(ls -A "${checkout_dir}" 2>/dev/null)" ]]; then
        echo "git-nook: note: ${ref} already exists at the target and ${dir}/ is not empty."
        echo "git-nook: commit your local files, then reconcile:"
        echo "git-nook:   git nook -n ${name} run add --all && git nook -n ${name} run commit -m 'local files'"
        echo "git-nook:   git nook -n ${name} run pull --no-rebase --no-edit --allow-unrelated-histories"
        return 0
    fi
    if git --git-dir="${gitdir}" fetch --quiet origin \
        && git --git-dir="${gitdir}" --work-tree="${checkout_dir}" reset --hard --quiet refs/remotes/origin/main; then
        if ! materialize_one "${name}"; then
            rollback_add "${name}" "${dir}" "${toplevel}" "${gitdir}" "${container_dir}" "${made_link}" "${made_ckout}"
            err "bootstrap from ${url} failed; the nook was rolled back — fix the problem above and re-run add"
            exit 1
        fi
        echo "git-nook: bootstrapped ${dir}/ from ${ref}"
    else
        rollback_add "${name}" "${dir}" "${toplevel}" "${gitdir}" "${container_dir}" "${made_link}" "${made_ckout}"
        err "bootstrap from ${url} failed; the nook was rolled back — fix the problem above and re-run add"
        exit 1
    fi
}

cmd_list() {
    require_work_tree
    cd_to_toplevel
    local key dir name gitdir url found=0
    local content_path checkout_dir linked_note
    while read -r key dir; do
        [[ -n "${key}" ]] || continue
        found=1
        name="${key#nook.}"; name="${name%.dir}"
        gitdir=$(inner_git_dir "${name}")
        url=$(git --git-dir="${gitdir}" config --get remote.origin.url 2>/dev/null) || url="(no inner repo)"
        content_path="$(pwd)/${dir}"
        checkout_dir=$(canonical_worktree "${name}")
        linked_note=""
        if ! { [[ -L "${content_path}" ]] \
               && [[ "$(cd "${content_path}" 2>/dev/null && pwd -P)" == "$(cd "${checkout_dir}" 2>/dev/null && pwd -P)" ]]; }; then
            linked_note="  [not linked here: git nook materialize]"
        fi
        printf '%s\t%s/\t%s%s\n' "${name}" "${dir}" "${url}" "${linked_note}"
    done < <(git config --get-regexp '^nook\..*\.dir$' 2>/dev/null || true)
    if [[ "${found}" -eq 0 ]]; then
        echo "git-nook: no nooks configured here; create one with: git nook add <name> <target>"
    fi
}

cmd_materialize() {
    require_work_tree
    cd_to_toplevel
    local key dir name found=0 rc=0
    while read -r key dir; do
        [[ -n "${key}" ]] || continue
        found=1
        name="${key#nook.}"; name="${name%.dir}"
        if ! materialize_one "${name}"; then
            rc=1
        fi
    done < <(git config --get-regexp '^nook\..*\.dir$' 2>/dev/null || true)
    if [[ "${found}" -eq 0 ]]; then
        echo "git-nook: no nooks configured here; create one with: git nook add <name> <target>"
    fi
    return "${rc}"
}

cmd_show() {
    require_work_tree
    cd_to_toplevel
    local name="${1:-}" dir gitdir checkout_dir content_path state linked t
    [[ -n "${name}" ]] || { err "usage: git nook -n <name> show"; exit 1; }
    if ! dir=$(channel_dir "${name}"); then
        err "no nook named '${name}' (see: git nook list)"
        exit 1
    fi
    gitdir=$(inner_git_dir "${name}")
    checkout_dir=$(canonical_worktree "${name}")
    content_path="$(pwd)/${dir}"   # cd_to_toplevel put us at the work-tree root
    # A broken/missing inner repo degrades to empty fields rather than
    # aborting show; without the || guard, pipefail + set -e would kill the
    # script with git's raw 128.
    state=$(git --git-dir="${gitdir}" --work-tree="${dir}" status -sb 2>/dev/null | head -n 1) || state=""
    if [[ -L "${content_path}" ]] \
        && t=$(cd "${content_path}" 2>/dev/null && pwd -P) \
        && [[ -d "${checkout_dir}" ]] \
        && [[ "${t}" == "$(cd "${checkout_dir}" && pwd -P)" ]]; then
        linked="yes"
    else
        linked="no (run: git nook materialize)"
    fi
    echo "name:     ${name}"
    echo "dir:      ${dir}/"
    echo "git-dir:  ${gitdir}"
    echo "checkout: ${checkout_dir}/"
    echo "linked:   ${linked}"
    echo "url:      $(git --git-dir="${gitdir}" config --get remote.origin.url 2>/dev/null || echo '(none)')"
    echo "pushes:   $(git --git-dir="${gitdir}" config --get remote.origin.push 2>/dev/null || echo '(none)')"
    echo "state:    ${state}"
}

# Does the inner repo have commits on refs/heads/main not present on the
# upstream files ref? Returns 0 (true) if there is unpushed work.
has_unpushed() {
    local gd="$1"
    git --git-dir="${gd}" rev-parse --verify -q refs/heads/main >/dev/null 2>&1 || return 1
    if ! git --git-dir="${gd}" rev-parse --verify -q refs/remotes/origin/main >/dev/null 2>&1; then
        git --git-dir="${gd}" fetch -q origin 2>/dev/null || true
    fi
    if ! git --git-dir="${gd}" rev-parse --verify -q refs/remotes/origin/main >/dev/null 2>&1; then
        return 0
    fi
    local ahead
    ahead=$(git --git-dir="${gd}" rev-list --count refs/remotes/origin/main..refs/heads/main 2>/dev/null || echo 1)
    [[ "${ahead}" -gt 0 ]]
}

cmd_remove() {
    require_work_tree
    cd_to_toplevel
    local partial="${1:-}"; shift || true
    local force=""
    [[ "${1:-}" == "--force" ]] && force=1
    [[ -n "${partial}" ]] || { err "usage: git nook -n <name> remove [--force]"; exit 1; }
    local slug; slug=$(resolve_slug_prefix "${partial}") || exit 1
    local dir gitdir container_dir toplevel
    dir=$(channel_dir "${slug}")
    gitdir=$(inner_git_dir "${slug}")
    container_dir=$(canonical_container "${slug}")
    toplevel=$(pwd)

    if [[ -z "${force}" ]] && [[ -d "${gitdir}" ]] && has_unpushed "${gitdir}"; then
        err "nook '${slug}' has commits not on the upstream; push them, or re-run with --force to delete anyway"
        exit 1
    fi

    # Remove the per-worktree content path defensively: only unlink a symlink.
    # If it is a real directory (manually replaced, or a legacy flat layout),
    # leave it in place rather than risk the user's files, and say so.
    if [[ -L "${toplevel}/${dir}" ]]; then
        rm -f "${toplevel}/${dir}"
    elif [[ -e "${toplevel}/${dir}" ]]; then
        echo "git-nook: note: '${dir}' is not a git-nook symlink; leaving it in place." >&2
    fi

    git config --remove-section "nook.${slug}" 2>/dev/null || true
    remove_exclude_entry "${dir}"
    rm -rf "${gitdir}"
    rm -rf "${container_dir}"
    echo "git-nook: removed nook '${slug}' locally (upstream untouched)."
}

run_passthrough() {
    local name="$1"; shift
    local gitdir checkout_dir
    # Deliberately do NOT call `git rev-parse --show-toplevel` here (nor
    # anything else that requires a configured work tree). The caller's cwd
    # may be physically inside the parent's .git dir: the per-worktree
    # content path is a symlink to the nook's nested work-tree under
    # <common-git-dir>/nook/<name>.nook/<basename(dir)>, so `cd`-ing into a
    # nook (directly, or via a shell that resolves symlinks) puts $PWD there.
    # From such a cwd, git's ambient discovery still resolves
    # --git-dir/--git-common-dir and config correctly (it just walks up to
    # the real .git that contains the cwd) but --show-toplevel refuses
    # ("fatal: this operation must be run in a work tree") because there is
    # no work tree configured for that location. inner_git_dir only needs
    # common_git_dir; canonical_worktree additionally reads the
    # nook.<name>.dir config via channel_dir, which git resolves fine even
    # from inside .git. Both keep working here — so route everything through
    # those instead of toplevel.
    gitdir=$(inner_git_dir "${name}")
    checkout_dir=$(canonical_worktree "${name}")
    if [[ ! -d "${gitdir}" ]]; then
        err "nook '${name}' has no inner repo at ${gitdir} (was it deleted?)"
        exit 1
    fi
    if [[ ! -d "${checkout_dir}" ]]; then
        err "nook '${name}' has no checkout at ${checkout_dir}; run: git nook materialize (or: git nook add ${name} <target>)"
        exit 1
    fi
    # Resolve physically so the containment check below matches even through
    # symlinks (checkout_dir can come back through a symlinked path, e.g.
    # macOS /tmp -> /private/tmp; and the caller's cwd may itself be the
    # nook's per-worktree symlink, which resolves to this same checkout).
    checkout_dir=$(cd "${checkout_dir}" && pwd -P)
    # Predictable relative pathspecs: run from the checkout unless the caller
    # is already inside it. ([[ ]] with the variable quoted compares
    # literally even if the path contains glob metacharacters.)
    if [[ "$(pwd -P)/" != "${checkout_dir}/"* ]]; then
        cd "${checkout_dir}"
    fi
    exec git --git-dir="${gitdir}" --work-tree="${checkout_dir}" "$@"
    # exec never returns; guard against a future edit accidentally falling
    # through to the dispatch's unknown-nook error after doing real work.
    exit 1
}

# --- Dispatch -------------------------------------------------------------------

main() {
    case "${1:-}" in
        add)    shift; cmd_add "$@" ;;
        init)   shift; cmd_init "$@" ;;
        clone)  shift; cmd_clone "$@" ;;
        list)   shift; cmd_list "$@" ;;
        materialize) shift; cmd_materialize "$@" ;;
        --version | version) echo "git-nook ${VERSION}" ;;
        -h | --help | help | "") usage ;;
        -n | --name)
            local name
            if [[ $# -lt 2 ]]; then
                err "missing value for -n/--name"
                exit 1
            fi
            name="$2"
            shift 2
            validate_name "${name}" || exit 1
            # Resolve a plain/partial name to its slug when there's no exact
            # config key for it (e.g. init/clone-produced slugs carry a
            # provenance suffix the user didn't type). Ambiguous or no-match
            # falls through to the exact-match error paths below, preserving
            # existing messages for those cases.
            if ! channel_dir "${name}" >/dev/null 2>&1; then
                local resolved
                if resolved=$(resolve_slug_prefix "${name}" 2>/dev/null) && [[ -n "${resolved}" ]]; then
                    name="${resolved}"
                fi
            fi
            case "${1:-}" in
                show)
                    shift; cmd_show "${name}" "$@" ;;
                remove)
                    shift; cmd_remove "${name}" "$@" ;;
                run)
                    shift
                    require_git_repo
                    if ! channel_dir "${name}" >/dev/null 2>&1; then
                        err "no nook named '${name}' (see: git nook list)"
                        exit 1
                    fi
                    run_passthrough "${name}" "$@"
                    ;;
                "")
                    err "no command given for nook '${name}'"
                    exit 1
                    ;;
                *)
                    err "unknown command '${1}' for nook '${name}'"
                    exit 1
                    ;;
            esac
            ;;
        -*)
            err "unknown option '${1}'"
            usage >&2
            exit 1
            ;;
        *)
            err "unknown command '${1}'"
            echo "git-nook: see 'git nook list'; select a nook with 'git nook -n <name> <show|remove|run>'; create one with 'git nook add <name> <target>'" >&2
            exit 1
            ;;
    esac
}

# When sourced as a library (tests), skip running main.
if [[ -z "${GIT_NOOK_LIB:-}" ]]; then
    main "$@"
fi
