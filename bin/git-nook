#!/usr/bin/env bash
set -euo pipefail

# The tool always resolves the parent repo from $PWD; ambient git env
# vars (from wrapper scripts, hooks, prompts) would silently redirect
# every git call below.
unset GIT_DIR GIT_WORK_TREE GIT_COMMON_DIR GIT_INDEX_FILE

# git-nook — git for a hidden directory.
#
# A nook is an ordinary git repository whose git-dir hides under the parent
# repo's .git/ and whose worktree is a content dir the parent excludes.
# 'add' creates and wires one; every other operation is plain git run
# against it through the passthrough:
#
#   git nook add <name> <target> [--dir <d>] [--ref <tpl>]
#   git nook list | show <name> | remove <name>
#   git nook <name> <any-git-args...>
#
# Design: docs/plans/2026-07-05-git-nook-design.md

VERSION="0.2.0"

DEFAULT_REF_TEMPLATE='refs/nook/<owner>/<project>/<name>'
# shellcheck disable=SC2034 # consumed by the add/list/show/remove dispatch arms added in later tasks
RESERVED_NAMES=(add list show remove help version)

usage() {
    cat <<EOF
git-nook ${VERSION} — git for a hidden directory

Usage:
  git nook add <name> <target-url-or-remote> [--dir <dir>] [--ref <template>]
  git nook list
  git nook show <name>
  git nook remove <name>
  git nook <name> <git-args...>    # run any git command against the nook
  git nook --help | --version

A nook is a real git repository hidden inside this repo's .git directory,
with its worktree in an excluded content dir. 'add' wires its remote to a
custom ref (default: ${DEFAULT_REF_TEMPLATE}),
so push/pull/status work out of the box:

  git nook notes status
  git nook notes add --all
  git nook notes commit -m "something"
  git nook notes push
EOF
}

err() { echo "git-nook: error: $*" >&2; }

require_work_tree() {
    if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        err "not inside a git repository"
        exit 1
    fi
}

channel_dir() { git config --get "nook.${1}.dir"; }

# Absolute path of the parent's common git dir (worktree-safe; portable
# normalization because --git-common-dir may print a relative path).
# All wrapper commands cd to the parent toplevel first, so relative is safe
# to resolve against $PWD.
common_git_dir() {
    local out
    out=$(git rev-parse --git-common-dir)
    case "${out}" in
        /*) printf '%s\n' "${out}" ;;
        *)  printf '%s/%s\n' "$(pwd)" "${out}" ;;
    esac
}

inner_git_dir() { printf '%s/nook/%s.git\n' "$(common_git_dir)" "$1"; }

# Prints "<owner>\t<project>" derived from the origin remote URL, falling
# back to owner=local, project=<toplevel dirname> when there is no origin.
owner_and_project() {
    local url path owner project
    if url=$(git remote get-url origin 2>/dev/null); then
        case "${url}" in
            *://*) path="${url#*://}" ;;            # scheme://host/owner/repo
            *:*)   path="${url%%:*}/${url#*:}" ;;   # host:owner/repo (scp-like)
            *)     path="${url}" ;;                 # plain filesystem path
        esac
        path="${path%/}"
        path="${path%.git}"
        project=$(basename "${path}")
        owner=$(basename "$(dirname "${path}")")
        if [[ -z "${owner}" || "${owner}" == "." || "${owner}" == "/" ]]; then
            owner="local"
        fi
    else
        # shellcheck disable=SC2312 # rev-parse failure exits the script under set -e
        project=$(basename "$(git rev-parse --show-toplevel)")
        owner="local"
    fi
    printf '%s\t%s\n' "${owner}" "${project}"
}

# Resolve a ref template (<owner>/<project>/<name> tokens). A resolved value
# starting with refs/ is used verbatim; anything else goes under refs/heads/.
resolve_ref() {
    local tpl="$1" name="$2" owner project
    IFS=$'\t' read -r owner project < <(owner_and_project)
    tpl="${tpl//<owner>/${owner}}"
    tpl="${tpl//<project>/${project}}"
    tpl="${tpl//<name>/${name}}"
    [[ "${tpl}" == refs/* ]] || tpl="refs/heads/${tpl}"
    if ! git check-ref-format "${tpl}" >/dev/null 2>&1; then
        err "resolved ref '${tpl}' is not a valid git ref (check --ref and your origin URL)"
        return 1
    fi
    printf '%s\n' "${tpl}"
}

validate_name() {
    local name="$1" r
    for r in "${RESERVED_NAMES[@]}"; do
        if [[ "${name}" == "${r}" ]]; then
            err "'${name}' is a reserved subcommand name"
            return 1
        fi
    done
    if [[ "${name}" == -* || "${name}" == */* ]] \
        || ! git check-ref-format "refs/nook/${name}" >/dev/null 2>&1; then
        err "'${name}' is not a valid nook name (one path component, no leading '-')"
        return 1
    fi
}

# Absolute info/exclude path, worktree-safe (resolved after cd to toplevel).
exclude_file() {
    local out
    out=$(git rev-parse --git-path info/exclude)
    case "${out}" in
        /*) printf '%s\n' "${out}" ;;
        *)  printf '%s/%s\n' "$(pwd)" "${out}" ;;
    esac
}

add_exclude_entry() {
    local entry="$1" file
    file=$(exclude_file)
    mkdir -p "$(dirname "${file}")"
    if ! grep -qxF "${entry}" "${file}" 2>/dev/null; then
        # shellcheck disable=SC2312 # tail failure worst case adds a blank line
        if [[ -s "${file}" ]] && [[ "$(tail -c 1 "${file}")" != "" ]]; then
            printf '\n' >> "${file}"
        fi
        printf '%s\n' "${entry}" >> "${file}"
    fi
}

# shellcheck disable=SC2329 # consumed by the remove subcommand added in a later task
remove_exclude_entry() {
    local entry="$1" file tmp
    file=$(exclude_file)
    [[ -f "${file}" ]] || return 0
    tmp=$(mktemp)
    grep -vxF "${entry}" "${file}" > "${tmp}" || true
    mv "${tmp}" "${file}"
}

# --- Subcommands ------------------------------------------------------------------

cmd_add() {
    require_work_tree
    # shellcheck disable=SC2312 # rev-parse failure exits the script under set -e
    cd "$(git rev-parse --show-toplevel)"

    local name="" target="" dir="" ref_tpl="${DEFAULT_REF_TEMPLATE}"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dir)
                [[ $# -ge 2 ]] || { err "--dir requires a value"; exit 1; }
                dir="$2"; shift 2 ;;
            --ref)
                [[ $# -ge 2 ]] || { err "--ref requires a value"; exit 1; }
                ref_tpl="$2"; shift 2 ;;
            -*) err "unknown add option '$1'"; exit 1 ;;
            *)
                if [[ -z "${name}" ]]; then name="$1"
                elif [[ -z "${target}" ]]; then target="$1"
                else err "unexpected extra argument '$1'"; exit 1; fi
                shift ;;
        esac
    done
    if [[ -z "${name}" || -z "${target}" ]]; then
        err "usage: git nook add <name> <target-url-or-remote> [--dir <d>] [--ref <tpl>]"
        exit 1
    fi

    validate_name "${name}" || exit 1
    if channel_dir "${name}" >/dev/null 2>&1; then
        err "nook '${name}' already exists (see: git nook show ${name})"
        exit 1
    fi
    # Case-insensitive duplicate check: git config subsections are
    # case-sensitive, but the content dir and the inner git-dir live on a
    # filesystem that may not be. (tr, not ${var,,}: macOS ships bash 3.2.)
    local dup_key dup_name name_lc dup_lc
    name_lc=$(printf '%s' "${name}" | tr '[:upper:]' '[:lower:]')
    while read -r dup_key _; do
        [[ -n "${dup_key}" ]] || continue
        dup_name="${dup_key#nook.}"; dup_name="${dup_name%.dir}"
        dup_lc=$(printf '%s' "${dup_name}" | tr '[:upper:]' '[:lower:]')
        if [[ "${dup_lc}" == "${name_lc}" ]]; then
            err "nook '${dup_name}' already exists and differs from '${name}' only by case (unsafe on case-insensitive filesystems)"
            exit 1
        fi
    done < <(git config --get-regexp '^nook\..*\.dir$' 2>/dev/null || true)

    # Target: an existing parent remote name wins (resolved to its URL once,
    # now); otherwise anything with ':' or '/' is accepted as a literal URL.
    local url
    if url=$(git remote get-url "${target}" 2>/dev/null); then
        :
    elif [[ "${target}" == *[:/]* ]]; then
        url="${target}"
    else
        err "'${target}' is not a remote in this repo (and doesn't look like a URL)"
        exit 1
    fi

    [[ -n "${dir}" ]] || dir=".${name}"
    dir="${dir%/}"
    case "${dir}" in
        /* | . | .. | ./* | ../* | */.. | */../* | .git | .git/* | */.git | */.git/*)
            err "--dir must be a repo-relative path (no '..', not under .git)"
            exit 1 ;;
    esac

    # Refusals (design decision 7).
    if [[ -n "$(git ls-files -- "${dir}" 2>/dev/null)" ]]; then
        err "'${dir}/' contains files tracked by this repository; pick an untracked dir"
        exit 1
    fi
    local key other_dir other_name
    while read -r key other_dir; do
        [[ -n "${key}" ]] || continue
        other_name="${key#nook.}"; other_name="${other_name%.dir}"
        if [[ "${dir}/" == "${other_dir}/"* || "${other_dir}/" == "${dir}/"* ]]; then
            err "'${dir}/' overlaps nook '${other_name}' (${other_dir}/)"
            exit 1
        fi
    done < <(git config --get-regexp '^nook\..*\.dir$' 2>/dev/null || true)

    local ref gitdir
    # shellcheck disable=SC2310 # failure handled by the || exit
    ref=$(resolve_ref "${ref_tpl}" "${name}") || exit 1
    gitdir=$(inner_git_dir "${name}")
    if [[ -e "${gitdir}" ]]; then
        err "an inner repo already exists at ${gitdir}"
        err "it may hold history from a removed nook; delete it first if it is stale: rm -rf '${gitdir}'"
        exit 1
    fi

    # NOTE: mkdir -p may create multiple ancestor levels for a nested --dir;
    # created_dir only records the leaf. The bootstrap rollback (later task)
    # must not assume ancestors are cleaned up.
    local created_dir=0
    if [[ ! -d "${dir}" ]]; then
        mkdir -p "${dir}"
        # shellcheck disable=SC2034 # tracked for rollback-on-failure cleanup added in a later task
        created_dir=1
    fi
    add_exclude_entry "/${dir}/"

    mkdir -p "$(dirname "${gitdir}")"
    git init --quiet --bare "${gitdir}"
    git --git-dir="${gitdir}" symbolic-ref HEAD refs/heads/main
    git --git-dir="${gitdir}" config core.bare false
    git --git-dir="${gitdir}" config core.autocrlf false
    git --git-dir="${gitdir}" config remote.origin.url "${url}"
    git --git-dir="${gitdir}" config remote.origin.fetch "+${ref}:refs/remotes/origin/main"
    git --git-dir="${gitdir}" config remote.origin.push "refs/heads/main:${ref}"
    git --git-dir="${gitdir}" config branch.main.remote origin
    git --git-dir="${gitdir}" config branch.main.merge "${ref}"

    git config "nook.${name}.dir" "${dir}"

    echo "git-nook: added nook '${name}' (dir ${dir}/, target ${url}, ref ${ref})"
    # Bootstrap of an existing remote ref arrives in a later task; for now a
    # brand-new nook is immediately usable for local commits.
}

cmd_list() {
    require_work_tree
    # shellcheck disable=SC2312 # rev-parse failure exits the script under set -e
    cd "$(git rev-parse --show-toplevel)"
    local key dir name gitdir url found=0
    while read -r key dir; do
        [[ -n "${key}" ]] || continue
        found=1
        name="${key#nook.}"; name="${name%.dir}"
        gitdir=$(inner_git_dir "${name}")
        url=$(git --git-dir="${gitdir}" config --get remote.origin.url 2>/dev/null) || url="(no inner repo)"
        printf '%s\t%s/\t%s\n' "${name}" "${dir}" "${url}"
    done < <(git config --get-regexp '^nook\..*\.dir$' 2>/dev/null || true)
    if [[ "${found}" -eq 0 ]]; then
        echo "git-nook: no nooks configured here; create one with: git nook add <name> <target>"
    fi
}

cmd_show() {
    require_work_tree
    # shellcheck disable=SC2312 # rev-parse failure exits the script under set -e
    cd "$(git rev-parse --show-toplevel)"
    local name="${1:-}" dir gitdir state
    [[ -n "${name}" ]] || { err "usage: git nook show <name>"; exit 1; }
    if ! dir=$(channel_dir "${name}"); then
        err "no nook named '${name}' (see: git nook list)"
        exit 1
    fi
    gitdir=$(inner_git_dir "${name}")
    # A broken/missing inner repo degrades to empty fields rather than
    # aborting show; without the || guard, pipefail + set -e would kill the
    # script with git's raw 128.
    state=$(git --git-dir="${gitdir}" --work-tree="${dir}" status -sb 2>/dev/null | head -n 1) || state=""
    echo "name:    ${name}"
    echo "dir:     ${dir}/"
    echo "git-dir: ${gitdir}"
    echo "url:     $(git --git-dir="${gitdir}" config --get remote.origin.url 2>/dev/null || echo '(none)')"
    echo "pushes:  $(git --git-dir="${gitdir}" config --get remote.origin.push 2>/dev/null || echo '(none)')"
    echo "state:   ${state}"
}

run_passthrough() {
    local name="$1"; shift
    local toplevel dir gitdir worktree
    toplevel=$(git rev-parse --show-toplevel)
    dir=$(channel_dir "${name}")   # caller verified the nook exists
    gitdir=$(cd "${toplevel}" && inner_git_dir "${name}")
    worktree="${toplevel}/${dir}"
    if [[ ! -d "${gitdir}" ]]; then
        err "nook '${name}' has no inner repo at ${gitdir} (was it deleted?)"
        exit 1
    fi
    if [[ ! -d "${worktree}" ]]; then
        err "nook '${name}' has no content dir at ${worktree} (was it deleted?); recreate it with: mkdir -p '${worktree}' then restore via: git nook ${name} checkout -- ."
        exit 1
    fi
    # Resolve physically: pwd -P below resolves symlinks, so worktree must
    # too (toplevel can come back through a symlinked path, e.g. macOS
    # /tmp -> /private/tmp) or the containment check below never matches.
    worktree=$(cd "${worktree}" && pwd -P)
    # Predictable relative pathspecs: run from the nook's worktree unless the
    # caller is already somewhere inside it. ([[ ]] with the variable quoted
    # compares literally even if the path contains glob metacharacters.)
    if [[ "$(pwd -P)/" != "${worktree}/"* ]]; then
        cd "${worktree}"
    fi
    exec git --git-dir="${gitdir}" --work-tree="${worktree}" "$@"
    # exec never returns; guard against a future edit accidentally falling
    # through to the dispatch's unknown-nook error after doing real work.
    exit 1
}

# --- Dispatch -------------------------------------------------------------------

main() {
    case "${1:-}" in
        add)    shift; cmd_add "$@" ;;
        list)   shift; cmd_list "$@" ;;
        show)   shift; cmd_show "$@" ;;
        --version | version) echo "git-nook ${VERSION}" ;;
        -h | --help | help | "") usage ;;
        -*)
            err "unknown option '${1}'"
            usage >&2
            exit 1
            ;;
        *)
            require_work_tree
            if channel_dir "${1}" >/dev/null 2>&1; then
                run_passthrough "$@"
            fi
            err "unknown command or nook '${1}'"
            echo "git-nook: see nooks with 'git nook list'; create one with 'git nook add <name> <target>'" >&2
            exit 1
            ;;
    esac
}

main "$@"
