#!/usr/bin/env bash
set -euo pipefail

# br (wrapper) — Beads Orphanage. Shadows the real `br` binary on PATH.
# Everything outside the `orphanage` (alias `o`) namespace is exec'd through
# to the real binary untouched (exit codes, stdin/stdout, --json, TTY
# detection all pass through transparently). Note this includes bare
# `br init` and bare `br sync`, which are the real binary's own commands.
#
#   br orphanage init [...]     augmented init (+ optional --target <t>)
#   br orphanage target [...]   show/set this project's sync target
#   br orphanage sync [--all]   converge with the orphan branch
#   br orphanage --version      wrapper version
#
# Issue data syncs to an ORPHAN BRANCH on a per-project target repo,
# configured in the project's own git config (beadsOrphanage.*). See the
# design spec: docs/superpowers/specs/2026-07-03-br-orphanage-design.md

VERSION="0.1.0"

SELF=$(readlink -f "${BASH_SOURCE[0]}")

DEFAULT_BRANCH_TEMPLATE='<namespace>/<owner>/<project>'
DEFAULT_NAMESPACE='orphanage'

# Machine-local state (the project-paths index for `sync --all`). This is
# the ONLY on-disk state the wrapper owns; issue data never lives here.
DATA_DIR="${XDG_DATA_HOME:-${HOME}/.local/share}/br-orphanage"
PROJECT_PATHS_FILE="${DATA_DIR}/project-paths"

BEADS_DIR=".beads"
# The commit this machine last published: gc anchor, cheap fetch
# negotiation, and the merge base for divergence detection.
PUSHED_REF="refs/orphanage/pushed"
# Where sync fetches the remote tip (immune to FETCH_HEAD clobbering by
# concurrent unrelated fetches); also anchors fetched objects against gc.
FETCHED_REF="refs/orphanage/fetched"

# Files worth syncing. Deliberately excludes:
#   beads.db      — SQLite is local state; JSONL is the source of truth
#   .jsonl.lock   — transient runtime lock
#   .gitignore    — regenerated by `br init`
TRACKED_FILES=(
    config.yaml
    interactions.jsonl
    issues.jsonl
    metadata.json
    README.md
)

# Non-issue files resolved by the three-way rule during inbound merge.
# issues.jsonl is merged by the real br's import instead (per-issue,
# newest-wins, tombstone-protected).
# Empirical (br 0.2.16): `br sync --import-only` / `--flush-only` never
# touch interactions.jsonl at all (confirmed by truncating it to empty and
# running both — it stayed empty; no regeneration, no merge). That file is
# written only by `br audit record`, entirely separate from the issue DB.
# So it stays on the three-way path below, same as config.yaml/metadata.json.
THREEWAY_FILES=(
    config.yaml
    interactions.jsonl
    metadata.json
    README.md
)

# --- Find the real br binary (skip ourselves; no recursion) -------------------

find_real_br() {
    local dir cand
    local IFS=':'
    # shellcheck disable=SC2250 # deliberately unbraced/unquoted: word-splits PATH on the IFS=':' set above
    for dir in $PATH; do
        [[ -n "${dir}" ]] || continue
        cand="${dir}/br"
        [[ -x "${cand}" ]] && [[ -f "${cand}" ]] || continue
        # shellcheck disable=SC2312 # readlink failure just falls through to "not self"
        [[ "$(readlink -f "${cand}")" = "${SELF}" ]] && continue
        printf '%s\n' "${cand}"
        return 0
    done
    return 1
}

# shellcheck disable=SC2310 # failure handled explicitly by the || block below
REAL_BR=$(find_real_br) || {
    echo "br-orphanage: error: real 'br' binary not found in PATH" >&2
    echo "br-orphanage: install it first: https://github.com/Dicklesworthstone/beads_rust" >&2
    exit 1
}

# --- Shared helpers -----------------------------------------------------------

usage() {
    cat <<EOF
Beads Orphanage ${VERSION} — br wrapper syncing issue data to orphan branches

Usage:
  br orphanage init [--target <remote-or-url>] [args for real 'br init']
  br orphanage target [<remote-or-url>] [--branch <template>] [--namespace <ns>]
  br orphanage sync [--all]
  br orphanage --version

'br o ...' is an alias for 'br orphanage ...'.
Everything else is passed through to the real 'br' binary untouched.
EOF
}

require_work_tree() {
    if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        echo "br-orphanage: error: not inside a git repository" >&2
        exit 1
    fi
}

# --- Subcommand stubs (implemented in later tasks) ------------------------------

# The augmented init body, shared by cmd_init and (later) the sync bootstrap
# path. Runs the real init, reverts any top-level .gitignore changes, and
# ensures a worktree-safe '.beads/' exclude entry.
run_augmented_init() {
    local repo_root gitignore had_gitignore exclude_file
    repo_root=$(git rev-parse --show-toplevel)
    cd "${repo_root}"

    # Snapshot .gitignore. Empirically (real br v0.2.16) `br init` does NOT
    # touch a top-level .gitignore — this is a safety net in case a future
    # version reintroduces the old Go bd behavior.
    # NOTE: _snapshot is deliberately not `local` — the EXIT trap fires after
    # this function returns, when locals are out of scope (set -u pitfall).
    gitignore="${repo_root}/.gitignore"
    had_gitignore=0
    # A previous call's snapshot (bootstrap path may re-enter): sweep it now,
    # BEFORE the reset below clobbers its path, since installing our trap
    # further down would overwrite the one guarding it.
    [[ -n "${_snapshot:-}" ]] && rm -f "${_snapshot}"
    _snapshot=""
    if [[ -f "${gitignore}" ]]; then
        had_gitignore=1
        _snapshot=$(mktemp)
        trap 'rm -f "${_snapshot:-}"' EXIT
        cp "${gitignore}" "${_snapshot}"
    fi

    "${REAL_BR}" init "$@"

    if [[ "${had_gitignore}" -eq 1 ]]; then
        if ! cmp -s "${_snapshot}" "${gitignore}" 2>/dev/null; then
            cp "${_snapshot}" "${gitignore}"
            echo "br-orphanage: reverted .gitignore changes made by 'br init'"
        fi
    elif [[ -f "${gitignore}" ]]; then
        rm "${gitignore}"
        echo "br-orphanage: removed .gitignore created by 'br init'"
    fi

    # --git-path resolves correctly in worktrees/submodules.
    exclude_file=$(git rev-parse --git-path info/exclude)
    mkdir -p "$(dirname "${exclude_file}")"
    if ! grep -qxF '.beads/' "${exclude_file}" 2>/dev/null; then
        # shellcheck disable=SC2312 # tail failure worst case adds a blank line
        if [[ -s "${exclude_file}" ]] && [[ "$(tail -c 1 "${exclude_file}")" != "" ]]; then
            printf '\n' >> "${exclude_file}"
        fi
        printf '.beads/\n' >> "${exclude_file}"
        echo "br-orphanage: added '.beads/' to ${exclude_file}"
    fi
}

cmd_init() {
    require_work_tree
    local target="" passthru=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --target)
                [[ $# -ge 2 ]] || { echo "br-orphanage: error: --target requires a value" >&2; exit 1; }
                target="$2"
                shift 2 ;;
            *)
                passthru+=("$1")
                shift ;;
        esac
    done

    run_augmented_init ${passthru[@]+"${passthru[@]}"}

    if [[ -n "${target}" ]]; then
        # Subshell: cmd_target calls `exit 1` on validation failure rather than
        # returning, which would skip our note below — the subshell contains
        # that exit so we can report that init itself already succeeded.
        if ! ( cmd_target "${target}" ); then
            echo "br-orphanage: note: init succeeded; the sync target was NOT set — fix and re-run: br orphanage target ${target}" >&2
            exit 1
        fi
    fi
}

# Prints "<owner>\t<project>" derived from the origin remote URL, falling
# back to owner=local, project=<toplevel dirname> when there is no origin.
owner_and_project() {
    local url path owner project
    if url=$(git remote get-url origin 2>/dev/null); then
        case "${url}" in
            *://*) path="${url#*://}" ;;            # scheme://host/owner/repo
            *:*)   path="${url%%:*}/${url#*:}" ;;   # host:owner/repo (scp-like)
            *)     path="${url}" ;;                 # plain filesystem path
        esac
        path="${path%/}"
        path="${path%.git}"
        project=$(basename "${path}")
        owner=$(basename "$(dirname "${path}")")
        if [[ -z "${owner}" || "${owner}" == "." || "${owner}" == "/" ]]; then
            owner="local"
        fi
    else
        # shellcheck disable=SC2312 # rev-parse failure exits the script under set -e
        project=$(basename "$(git rev-parse --show-toplevel)")
        owner="local"
    fi
    printf '%s\t%s\n' "${owner}" "${project}"
}

# shellcheck disable=SC2329 # used by the sync engine added in a later task
project_name() {
    local owner project
    IFS=$'\t' read -r owner project < <(owner_and_project)
    printf '%s\n' "${project}"
}

# Resolve the branch-name template (beadsOrphanage.branch, tokens
# <namespace>/<owner>/<project>) to a concrete branch name.
branch_name() {
    local tpl ns owner project
    tpl=$(git config --get beadsOrphanage.branch 2>/dev/null) || tpl="${DEFAULT_BRANCH_TEMPLATE}"
    ns=$(git config --get beadsOrphanage.namespace 2>/dev/null) || ns="${DEFAULT_NAMESPACE}"
    IFS=$'\t' read -r owner project < <(owner_and_project)
    tpl="${tpl//<namespace>/${ns}}"
    tpl="${tpl//<owner>/${owner}}"
    tpl="${tpl//<project>/${project}}"
    if ! git check-ref-format --branch "${tpl}" >/dev/null 2>&1; then
        echo "br-orphanage: error: resolved branch name '${tpl}' is not a valid git branch name (check beadsOrphanage.branch/namespace and your origin URL)" >&2
        return 1
    fi
    printf '%s\n' "${tpl}"
}

# Resolve beadsOrphanage.target to a fetchable/pushable URL on stdout.
# Precedence is remote-first: a stored value naming an existing remote
# (remote names may contain '/') resolves to that remote's URL at run time,
# so URL changes track; otherwise a value containing ':' or '/' is a literal
# URL. Returns 1 with guidance if unset, or an error if the value is neither
# an existing remote nor URL-shaped.
resolve_target_url() {
    local t
    if ! t=$(git config --get beadsOrphanage.target 2>/dev/null); then
        echo "br-orphanage: error: no sync target configured for this project" >&2
        echo "br-orphanage: set one with: br orphanage target <remote-or-url>" >&2
        return 1
    fi
    if git remote get-url "${t}" 2>/dev/null; then
        return 0
    fi
    if [[ "${t}" == *[:/]* ]]; then
        printf '%s\n' "${t}"
        return 0
    fi
    echo "br-orphanage: error: configured target remote '${t}' does not exist in this repo" >&2
    return 1
}

cmd_target() {
    require_work_tree
    if [[ $# -eq 0 ]]; then
        local stored url branch
        if ! stored=$(git config --get beadsOrphanage.target 2>/dev/null); then
            echo "br-orphanage: error: no sync target configured for this project" >&2
            echo "br-orphanage: set one with: br orphanage target <remote-or-url>" >&2
            exit 1
        fi
        # shellcheck disable=SC2310 # failure handled by the || exit
        url=$(resolve_target_url) || exit 1
        branch=$(branch_name)
        echo "target: ${stored}"
        echo "url:    ${url}"
        echo "branch: ${branch}"
        return 0
    fi

    local target=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --branch)
                if [[ $# -lt 2 || "${2}" == -* ]]; then
                    echo "br-orphanage: error: --branch requires a value" >&2
                    exit 1
                fi
                git config beadsOrphanage.branch "$2"
                shift 2 ;;
            --namespace)
                if [[ $# -lt 2 || "${2}" == -* ]]; then
                    echo "br-orphanage: error: --namespace requires a value" >&2
                    exit 1
                fi
                git config beadsOrphanage.namespace "$2"
                shift 2 ;;
            -*)
                echo "br-orphanage: error: unknown target option '${1}'" >&2
                exit 1 ;;
            *)
                if [[ -n "${target}" ]]; then
                    echo "br-orphanage: error: unexpected extra argument '${1}'" >&2
                    exit 1
                fi
                target="$1"
                shift ;;
        esac
    done

    if [[ -n "${target}" ]]; then
        # Remote-first, mirroring resolve_target_url: an existing remote name
        # wins; otherwise anything with ':' or '/' is accepted as a literal URL.
        if git remote get-url "${target}" >/dev/null 2>&1; then
            : # existing remote name
        elif [[ "${target}" != *[:/]* ]]; then
            echo "br-orphanage: error: '${target}' is not a remote in this repo (and doesn't look like a URL)" >&2
            exit 1
        fi
        git config beadsOrphanage.target "${target}"
        echo "br-orphanage: target set to '${target}' for this clone"
    fi
}

# Record (or update) this machine's absolute path for a project name in the
# machine-local index. Idempotent per project name. Format: one
# "name<TAB>absolute-path" pair per line.
# Known lost-update race (accepted): two genuinely PARALLEL invocations for
# DIFFERENT projects can each read-filter-append-mv and one entry loses.
# Serial use and `sync --all` (which iterates serially) are unaffected, and
# a lost entry self-heals on that project's next sync.
# Every step checks its own status: this runs inside `if (subshell)` from
# sync --all, where `set -e` is inert.
record_project_path() {
    local name="$1" path="$2" tmp
    if ! mkdir -p "${DATA_DIR}"; then
        echo "br-orphanage: error: could not create data dir ${DATA_DIR}" >&2
        return 1
    fi
    if ! tmp=$(mktemp "${DATA_DIR}/project-paths.XXXXXX"); then
        echo "br-orphanage: error: could not create temp file in ${DATA_DIR}" >&2
        return 1
    fi
    if [[ -f "${PROJECT_PATHS_FILE}" ]]; then
        # awk, not grep -v: a name with regex metacharacters must match literally.
        if ! awk -F'\t' -v n="${name}" '$1 != n' "${PROJECT_PATHS_FILE}" > "${tmp}"; then
            rm -f "${tmp}"
            echo "br-orphanage: error: could not rewrite project-path index" >&2
            return 1
        fi
    fi
    if ! printf '%s\t%s\n' "${name}" "${path}" >> "${tmp}"; then
        rm -f "${tmp}"
        echo "br-orphanage: error: could not append to project-path index temp file" >&2
        return 1
    fi
    if ! mv "${tmp}" "${PROJECT_PATHS_FILE}"; then
        rm -f "${tmp}"
        echo "br-orphanage: error: could not move index into place at ${PROJECT_PATHS_FILE}" >&2
        return 1
    fi
}

record_index_entry() {
    local name="$1" toplevel
    if ! toplevel=$(git rev-parse --show-toplevel); then
        echo "br-orphanage: error: could not resolve project toplevel for ${name}" >&2
        return 1
    fi
    # shellcheck disable=SC2310 # failure handled by caller
    record_project_path "${name}" "${toplevel}"
}

# Build the snapshot tree from the tracked files present in .beads/.
# Prints the tree SHA. Fails if zero trackable files exist.
build_tree() {
    local f sha entries="" count=0
    for f in "${TRACKED_FILES[@]}"; do
        [[ -f "${BEADS_DIR}/${f}" ]] || continue
        if ! sha=$(git hash-object -w "${BEADS_DIR}/${f}"); then
            echo "br-orphanage: error: hash-object failed for ${f}" >&2
            return 1
        fi
        entries+="100644 blob ${sha}"$'\t'"${f}"$'\n'
        count=$((count + 1))
    done
    if [[ "${count}" -eq 0 ]]; then
        echo "br-orphanage: error: no trackable beads files found in ${BEADS_DIR}/" >&2
        return 1
    fi
    printf '%s' "${entries}" | git mktree
}

# Inbound merge: the remote branch has commits this machine hasn't merged.
# $1 = remote tip SHA, $2 = merge base SHA (may be empty: first sync from
# this machine against an existing branch).
#
# Issues merge through the real br (import is per-issue, newest-wins, and
# tombstone-protected — deletions are records, not absences, so they
# propagate and never resurrect; verified against br 0.2.16).
#
# Non-issue files use a per-file three-way by blob SHA with base =
# refs/orphanage/pushed. Local wins on both-changed because recoverability
# is asymmetric: the remote version stays in branch history forever, while
# the local edit exists only in .beads/ (excluded from the project's git)
# and would be destroyed with no undo.
merge_inbound() {
    local tip="$1" base="$2" f local_sha base_sha remote_sha
    local import_out local_ids remote_ids
    if git cat-file -e "${tip}:issues.jsonl" 2>/dev/null; then
        if ! git cat-file blob "${tip}:issues.jsonl" > "${BEADS_DIR}/issues.jsonl"; then
            echo "br-orphanage: error: could not extract remote issues.jsonl" >&2
            return 1
        fi
        # Capture the import report: it is still shown to the user, and it
        # doubles as the no-change detector for the byte-convergence
        # adoption further below.
        if ! import_out=$("${REAL_BR}" sync --import-only 2>&1); then
            printf '%s\n' "${import_out}" >&2
            echo "br-orphanage: error: 'br sync --import-only' failed during inbound merge" >&2
            return 1
        fi
        printf '%s\n' "${import_out}"
        # --force: flush-only's dirty-tracking short-circuits to a no-op when
        # nothing changed since the last export, which would leave the file
        # we just clobbered with the remote's issues.jsonl (above) missing
        # any local issues that were already flushed (and thus non-dirty)
        # before this merge — --force makes this a full DB -> JSONL export
        # regardless of dirty state, so the file reflects the FULL post-merge
        # DB (remote issues just imported + pre-existing local ones).
        if ! "${REAL_BR}" sync --flush-only --force; then
            echo "br-orphanage: error: 'br sync --flush-only' failed after inbound merge" >&2
            return 1
        fi

        # Byte-convergence adoption. br's import/export round-trip is not
        # byte-stable across machines: e.g. (br 0.2.16, diagnosed here) a
        # tombstone exported by the machine that DELETED the issue carries
        # no closed_at field, but a machine that imports that tombstone
        # back-fills closed_at on its forced export — while the originating
        # machine's import leaves its own row untouched ("Tombstone
        # protected") and so re-exports WITHOUT closed_at. Publishing our
        # force-flushed bytes on such rounds would flap the tree hash
        # between machines forever. When (a) the import changed nothing in
        # the DB and (b) both files contain exactly the same issue-id set,
        # the two files are semantically identical and differ only in
        # serialization — adopt the remote bytes verbatim so both machines
        # publish identical trees and the flap terminates. Id-set equality
        # alone is a necessary-but-not-sufficient proxy for semantic
        # equality (equal ids could still carry different field values);
        # it's the no-DB-change guard that carries the semantic weight,
        # and the combination has been verified against br 0.2.16. Every
        # guard failure below degrades to keeping the force-flushed bytes:
        # correct union, at worst one extra commit, never data loss.
        #
        # No-change detection: br omits/zeroes the Created/Updated report
        # lines when nothing changed. If br's wording ever changes so these
        # lines vanish entirely, this check could misread a changed round
        # as unchanged — the id-set equality below still gates adoption,
        # bounding the residual risk.
        if ! grep -qE 'Created: [1-9]' <<< "${import_out}" \
            && ! grep -qE 'Updated: [1-9]' <<< "${import_out}"; then
            # br serializes "id" as the first key of every JSONL line. If
            # that format assumption ever breaks, the extracted sets simply
            # won't match and we keep the force-flushed bytes (safe).
            local_ids=$(sed -n 's/^{"id":"\([^"]*\)".*/\1/p' "${BEADS_DIR}/issues.jsonl" 2>/dev/null | sort) || local_ids=""
            remote_ids=$(git cat-file blob "${tip}:issues.jsonl" 2>/dev/null | sed -n 's/^{"id":"\([^"]*\)".*/\1/p' | sort) || remote_ids=""
            if [[ -n "${local_ids}" && "${local_ids}" == "${remote_ids}" ]]; then
                if ! git cat-file blob "${tip}:issues.jsonl" > "${BEADS_DIR}/issues.jsonl"; then
                    echo "br-orphanage: error: could not re-extract remote issues.jsonl" >&2
                    return 1
                fi
                echo "br-orphanage: adopted remote serialization of issues.jsonl (no content changes)"
            fi
        fi
    fi

    for f in "${THREEWAY_FILES[@]}"; do
        local_sha=""
        base_sha=""
        remote_sha=""
        if [[ -f "${BEADS_DIR}/${f}" ]]; then
            if ! local_sha=$(git hash-object "${BEADS_DIR}/${f}"); then
                echo "br-orphanage: error: hash-object failed for ${f}" >&2
                return 1
            fi
        fi
        if [[ -n "${base}" ]]; then
            base_sha=$(git rev-parse -q --verify "${base}:${f}" 2>/dev/null || true)
        fi
        remote_sha=$(git rev-parse -q --verify "${tip}:${f}" 2>/dev/null || true)

        # Already identical (including both absent): nothing to do.
        [[ "${remote_sha}" == "${local_sha}" ]] && continue

        if [[ "${local_sha}" == "${base_sha}" ]]; then
            # Local unchanged since last publish -> adopt the remote state.
            if [[ -n "${remote_sha}" ]]; then
                if ! git cat-file blob "${tip}:${f}" > "${BEADS_DIR}/${f}"; then
                    echo "br-orphanage: error: could not extract remote ${f}" >&2
                    return 1
                fi
            else
                rm -f "${BEADS_DIR}/${f}"
            fi
        elif [[ "${remote_sha}" == "${base_sha}" ]]; then
            : # Remote unchanged -> keep local; it will publish with this sync.
        else
            echo "br-orphanage: warning: both local and remote changed ${f}; kept local. Remote version preserved at ${tip} — view it with: git cat-file blob ${tip}:${f}" >&2
        fi
    done
}

# Abort a partial bootstrap: everything under .beads/ was created by this
# very bootstrap attempt (we only run when it was absent), so removing it
# returns the project to a cleanly re-bootstrappable state instead of
# stranding it half-initialized (sync_one would otherwise fail against the
# broken workspace forever, and its empty-base merge could publish init's
# throwaway config.yaml to the shared branch).
bootstrap_fail() {
    echo "$1" >&2
    echo "br-orphanage: bootstrap failed partway; removed the partially-created ${BEADS_DIR}/ — fix the problem above and re-run 'br orphanage sync'" >&2
    rm -rf "${BEADS_DIR}"
    exit 1
}

# Bootstrap: no .beads/ yet (fresh clone / new machine). Requires the orphan
# branch to already exist at the target; a brand-new project should run
# `br orphanage init` instead. Exits (not returns) — only reachable from the
# single-project cmd_sync path.
sync_bootstrap() {
    local name url branch lsout tip f extracted=0
    name=$(project_name)
    # shellcheck disable=SC2310 # failure handled by the || exit
    url=$(resolve_target_url) || exit 1
    # shellcheck disable=SC2310 # failure handled by the || exit
    branch=$(branch_name) || exit 1

    if ! lsout=$(git ls-remote "${url}" "refs/heads/${branch}"); then
        echo "br-orphanage: error: could not contact target ${url}" >&2
        exit 1
    fi
    if [[ -z "${lsout}" ]]; then
        echo "br-orphanage: error: no ${BEADS_DIR}/ here and no '${branch}' branch at the target." >&2
        echo "br-orphanage: for a brand-new project, run 'br orphanage init' first, then sync." >&2
        exit 1
    fi

    run_augmented_init

    # Everything from here on runs with a bootstrap-created .beads/ in place;
    # any failure goes through bootstrap_fail so the partial workspace is
    # removed rather than stranding the project (see bootstrap_fail).
    # Fetch into the dedicated ref (see FETCHED_REF) rather than FETCH_HEAD.
    if ! git fetch --quiet "${url}" "+refs/heads/${branch}:${FETCHED_REF}"; then
        bootstrap_fail "br-orphanage: error: fetch of '${branch}' from ${url} failed"
    fi
    if ! tip=$(git rev-parse -q --verify "${FETCHED_REF}"); then
        bootstrap_fail "br-orphanage: error: could not resolve ${FETCHED_REF} after fetch"
    fi
    for f in "${TRACKED_FILES[@]}"; do
        if git cat-file -e "${tip}:${f}" 2>/dev/null; then
            if ! git cat-file blob "${tip}:${f}" > "${BEADS_DIR}/${f}"; then
                bootstrap_fail "br-orphanage: error: could not extract ${f}"
            fi
            extracted=$((extracted + 1))
        fi
    done
    if [[ "${extracted}" -eq 0 ]]; then
        bootstrap_fail "br-orphanage: error: nothing restorable on '${branch}' at ${url}"
    fi

    if ! "${REAL_BR}" sync --import-only; then
        bootstrap_fail "br-orphanage: error: 'br sync --import-only' failed during bootstrap"
    fi
    git update-ref "${PUSHED_REF}" "${tip}"
    # shellcheck disable=SC2310 # failure handled by the || exit
    record_index_entry "${name}" || exit 1
    echo "Bootstrapped ${name} from ${branch} (${extracted} file(s)) and imported into the database."
}

# Core single-project sync, run from the project toplevel with .beads/
# present. Returns 0 on success (incl. no-op), 1 on failure — never exits,
# so `sync --all` can aggregate. Every command's status is checked
# explicitly: this runs inside `if (subshell)` from sync --all where
# `set -e` is inert.
sync_one() {
    local name url branch remote_tip="" base="" lsout tree
    name=$(project_name)
    # shellcheck disable=SC2310 # failure handled explicitly
    if ! url=$(resolve_target_url); then
        return 1
    fi
    # shellcheck disable=SC2310 # failure handled explicitly
    if ! branch=$(branch_name); then
        return 1
    fi

    if ! "${REAL_BR}" sync --flush-only; then
        echo "br-orphanage: error: 'br sync --flush-only' failed for ${name}" >&2
        return 1
    fi

    # ls-remote distinguishes a missing branch (first sync) from
    # network/auth failure.
    if ! lsout=$(git ls-remote "${url}" "refs/heads/${branch}"); then
        echo "br-orphanage: error: could not contact target ${url}" >&2
        return 1
    fi
    if [[ -n "${lsout}" ]]; then
        # Fetch into a dedicated local ref: FETCH_HEAD is a single global
        # file per repo, so a concurrent unrelated `git fetch` could clobber
        # it between our fetch and the rev-parse. The + forces update: after
        # retargeting, the previously-fetched tip may not fast-forward.
        if ! git fetch --quiet "${url}" "+refs/heads/${branch}:${FETCHED_REF}"; then
            echo "br-orphanage: error: fetch of '${branch}' from ${url} failed" >&2
            return 1
        fi
        if ! remote_tip=$(git rev-parse -q --verify "${FETCHED_REF}" 2>/dev/null); then
            echo "br-orphanage: error: could not resolve ${FETCHED_REF} after fetch" >&2
            return 1
        fi
    fi

    base=$(git rev-parse -q --verify "${PUSHED_REF}" 2>/dev/null || true)

    if [[ -n "${remote_tip}" && "${remote_tip}" != "${base}" ]]; then
        # shellcheck disable=SC2310 # failure handled explicitly
        if ! merge_inbound "${remote_tip}" "${base}"; then
            return 1
        fi
    fi

    # shellcheck disable=SC2310 # failure handled explicitly
    if ! tree=$(build_tree); then
        return 1
    fi

    if [[ -n "${remote_tip}" ]] && [[ "${tree}" == "$(git rev-parse "${remote_tip}^{tree}" 2>/dev/null)" ]]; then
        if ! git update-ref "${PUSHED_REF}" "${remote_tip}"; then
            echo "br-orphanage: error: could not update ${PUSHED_REF}" >&2
            return 1
        fi
        # shellcheck disable=SC2310 # failure handled explicitly
        if ! record_index_entry "${name}"; then
            return 1
        fi
        echo "Already in sync for ${name}."
        return 0
    fi

    local parent_args=() commit
    if [[ -n "${remote_tip}" ]]; then
        parent_args=(-p "${remote_tip}")
    fi
    if ! commit=$(git commit-tree "${tree}" ${parent_args[@]+"${parent_args[@]}"} -m "sync beads: ${name}"); then
        echo "br-orphanage: error: commit-tree failed for ${name}" >&2
        return 1
    fi
    if ! git push --quiet "${url}" "${commit}:refs/heads/${branch}"; then
        echo "br-orphanage: error: push to ${url} (${branch}) was rejected — another machine may have synced just now; re-run 'br orphanage sync'" >&2
        return 1
    fi
    if ! git update-ref "${PUSHED_REF}" "${commit}"; then
        echo "br-orphanage: error: could not update ${PUSHED_REF}" >&2
        return 1
    fi
    # shellcheck disable=SC2310 # failure handled explicitly
    if ! record_index_entry "${name}"; then
        return 1
    fi
    # shellcheck disable=SC2312 # rev-parse of a commit we just created cannot fail meaningfully
    echo "Beads synced for ${name} -> $(git rev-parse --short "${commit}") (${branch})"
}

# Iterate the machine-local index and sync each recorded project. Unlike the
# single-project path this is runnable from anywhere (no require_work_tree).
# Skips warn; only real per-project sync failures make the run exit nonzero.
# The index is read on fd 3 so nothing in the loop (the real br, git) can
# eat the loop's input from stdin.
cmd_sync_all() {
    if [[ ! -f "${PROJECT_PATHS_FILE}" ]]; then
        echo "br-orphanage: no project index yet; nothing to sync."
        return 0
    fi

    local name path failed=0 synced=0 skipped=0
    # The `|| [[ -n ... ]]` processes a final line that lacks a trailing
    # newline (a hand-edited index) instead of silently dropping it — the
    # wrapper itself always newline-terminates via record_project_path.
    while IFS=$'\t' read -r -u 3 name path || [[ -n "${name:-}" ]]; do
        [[ -n "${name}" ]] || continue
        if [[ ! -d "${path}" ]]; then
            echo "br-orphanage: warning: skipping '${name}' (recorded path no longer exists: ${path})" >&2
            skipped=$((skipped + 1))
            continue
        fi
        if ! git -C "${path}" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
            echo "br-orphanage: warning: skipping '${name}' (recorded path is not a git repo: ${path})" >&2
            skipped=$((skipped + 1))
            continue
        fi
        if [[ ! -d "${path}/${BEADS_DIR}" ]]; then
            echo "br-orphanage: warning: skipping '${name}' (no ${BEADS_DIR} at recorded path: ${path})" >&2
            skipped=$((skipped + 1))
            continue
        fi
        if ! git -C "${path}" config --get beadsOrphanage.target >/dev/null 2>&1; then
            echo "br-orphanage: warning: skipping '${name}' (no sync target configured at ${path})" >&2
            skipped=$((skipped + 1))
            continue
        fi

        echo "br-orphanage: syncing '${name}' (${path})..."
        # shellcheck disable=SC2310 # failure handled explicitly below (warn + aggregate)
        if ( cd "${path}" && sync_one ); then
            synced=$((synced + 1))
        else
            echo "br-orphanage: warning: sync failed for '${name}'" >&2
            failed=$((failed + 1))
        fi
    done 3< "${PROJECT_PATHS_FILE}"

    echo "br-orphanage: sync --all summary: ${synced} synced, ${skipped} skipped, ${failed} failed"
    [[ "${failed}" -eq 0 ]]
}

cmd_sync() {
    if [[ "${1:-}" == "--all" ]]; then
        shift
        if [[ $# -gt 0 ]]; then
            echo "br-orphanage: error: unexpected arguments after --all: $*" >&2
            exit 1
        fi
        cmd_sync_all
        return $?
    fi
    # Reject unknown options loudly rather than silently running a sync the
    # user didn't ask for (e.g. a typo'd `--al`).
    if [[ "${1:-}" == -* ]]; then
        echo "br-orphanage: error: unknown sync option '${1}' (did you mean --all?)" >&2
        exit 1
    fi

    require_work_tree
    # shellcheck disable=SC2312 # rev-parse failure exits the script under set -e
    cd "$(git rev-parse --show-toplevel)"

    if [[ ! -d "${BEADS_DIR}" ]]; then
        sync_bootstrap
    else
        # shellcheck disable=SC2310 # failure handled by the || exit
        sync_one || exit 1
    fi
}

# --- Dispatch -------------------------------------------------------------------

cmd_orphanage() {
    case "${1:-}" in
        init)      shift; cmd_init "$@" ;;
        target)    shift; cmd_target "$@" ;;
        sync)      shift; cmd_sync "$@" ;;
        --version) echo "br-orphanage ${VERSION}" ;;
        "")        usage ;;
        *)
            echo "br-orphanage: error: unknown subcommand '${1}'" >&2
            usage >&2
            exit 1
            ;;
    esac
}

case "${1:-}" in
    orphanage|o) shift; cmd_orphanage "$@" ;;
    *)           exec "${REAL_BR}" "$@" ;;
esac
