#!/usr/bin/env bash
set -euo pipefail

# br (wrapper) — Beads Orphanage. Shadows the real `br` binary on PATH.
# Everything outside the `orphanage` (alias `o`) namespace is exec'd through
# to the real binary untouched (exit codes, stdin/stdout, --json, TTY
# detection all pass through transparently). Note this includes bare
# `br init` and bare `br sync`, which are the real binary's own commands.
#
#   br orphanage init [...]     augmented init (+ optional --target <t>)
#   br orphanage target [...]   show/set this project's sync target
#   br orphanage sync [--all]   converge with the orphan branch
#   br orphanage --version      wrapper version
#
# Issue data syncs to an ORPHAN BRANCH on a per-project target repo,
# configured in the project's own git config (beadsOrphanage.*). See the
# design spec: docs/superpowers/specs/2026-07-03-br-orphanage-design.md

VERSION="0.1.0"

SELF=$(readlink -f "${BASH_SOURCE[0]}")

# NOTE: further constants (data dir, tracked files, refs, template defaults)
# are added by later tasks, in the task that first uses them — defining them
# now would fail shellcheck (SC2034 unused) at this task's commit.

# --- Find the real br binary (skip ourselves; no recursion) -------------------

find_real_br() {
    local dir cand
    local IFS=':'
    # shellcheck disable=SC2250 # deliberately unbraced/unquoted: word-splits PATH on the IFS=':' set above
    for dir in $PATH; do
        [[ -n "${dir}" ]] || continue
        cand="${dir}/br"
        [[ -x "${cand}" ]] && [[ -f "${cand}" ]] || continue
        # shellcheck disable=SC2312 # readlink failure just falls through to "not self"
        [[ "$(readlink -f "${cand}")" = "${SELF}" ]] && continue
        printf '%s\n' "${cand}"
        return 0
    done
    return 1
}

# shellcheck disable=SC2310 # failure handled explicitly by the || block below
REAL_BR=$(find_real_br) || {
    echo "br-orphanage: error: real 'br' binary not found in PATH" >&2
    echo "br-orphanage: install it first: https://github.com/Dicklesworthstone/beads_rust" >&2
    exit 1
}

# --- Shared helpers -----------------------------------------------------------

usage() {
    cat <<EOF
Beads Orphanage ${VERSION} — br wrapper syncing issue data to orphan branches

Usage:
  br orphanage init [--target <remote-or-url>] [args for real 'br init']
  br orphanage target [<remote-or-url>] [--branch <template>] [--namespace <ns>]
  br orphanage sync [--all]
  br orphanage --version

'br o ...' is an alias for 'br orphanage ...'.
Everything else is passed through to the real 'br' binary untouched.
EOF
}

# --- Subcommand stubs (implemented in later tasks) ------------------------------

cmd_init() {
    echo "br-orphanage: error: 'init' not implemented yet" >&2
    exit 1
}

cmd_target() {
    echo "br-orphanage: error: 'target' not implemented yet" >&2
    exit 1
}

cmd_sync() {
    echo "br-orphanage: error: 'sync' not implemented yet" >&2
    exit 1
}

# --- Dispatch -------------------------------------------------------------------

cmd_orphanage() {
    case "${1:-}" in
        init)      shift; cmd_init "$@" ;;
        target)    shift; cmd_target "$@" ;;
        sync)      shift; cmd_sync "$@" ;;
        --version) echo "br-orphanage ${VERSION}" ;;
        "")        usage ;;
        *)
            echo "br-orphanage: error: unknown subcommand '${1}'" >&2
            usage >&2
            exit 1
            ;;
    esac
}

case "${1:-}" in
    orphanage|o) shift; cmd_orphanage "$@" ;;
    *)           exec "${REAL_BR}" "$@" ;;
esac
