#!/usr/bin/env bash
set -euo pipefail

# br (wrapper) — lives in the beads-sync repo and shadows the real `br`
# binary on PATH. Intercepts a few subcommands; everything else is exec'd
# through to the real binary untouched (exit codes, stdin/stdout, --json,
# and TTY detection all pass through transparently).
#
# Intercepted commands:
#   br init [...]   Run real `br init`, revert any .gitignore changes it
#                   made, and add `.beads/` to .git/info/exclude so nothing
#                   beads-related ever appears in the project repo.
#   br push         Flush DB -> JSONL, copy into this repo's projects/<name>/,
#                   commit, and push. Also fast-forwards the sync repo first,
#                   which keeps these scripts themselves up to date. Records
#                   this project's absolute path in a machine-local index
#                   (see PROJECT_PATHS_FILE below) so `push --all` can find it.
#   br push --all   Pull the sync repo once, then walk every projects/<name>/
#                   directory and push each one whose path is known from the
#                   index. Unknown/stale entries are skipped with a warning
#                   rather than failing the whole run.
#   br restore      Pull the sync repo, copy projects/<name>/ back into
#                   .beads/, and `br sync --import-only`. Runs the augmented
#                   init first if the project has no .beads/ yet.
#
# Everything else: passed through to the real br.

# --- Locate ourselves and the sync repo --------------------------------------

SELF=$(readlink -f "${BASH_SOURCE[0]}")
SYNC_REPO=$(cd "$(dirname "${SELF}")/.." && pwd)
PROJECTS_DIR="${SYNC_REPO}/projects"
BEADS_DIR=".beads"

# Machine-local index of "project name -> absolute source path", so
# `br push --all` knows where each projects/<name>/ directory came from.
# This file is intentionally NEVER committed: it's specific to this machine's
# filesystem layout. It's kept OUTSIDE of any git-tracked content by being
# listed in the sync repo's own tracked .gitignore (SYNC_REPO/.gitignore,
# not to be confused with the per-project .gitignore invariants enforced by
# cmd_init above). A tracked .gitignore was chosen over `.git/info/exclude`
# because info/exclude lives in .git/ and does NOT survive a fresh clone —
# every new machine would see the index file as untracked-but-unignored
# clutter. A tracked .gitignore entry, by contrast, comes along for free on
# every clone.
PROJECT_PATHS_FILE="${SYNC_REPO}/.project-paths"

# Files worth versioning centrally. Deliberately excludes:
#   beads.db      — SQLite is local state; JSONL is the git source of truth
#   .jsonl.lock   — transient runtime lock
#   .gitignore    — regenerated by `br init`
TRACKED_FILES=(
    config.yaml
    interactions.jsonl
    issues.jsonl
    metadata.json
    README.md
)

# --- Find the real br binary (skip ourselves; no recursion) -------------------

find_real_br() {
    local dir cand
    local IFS=':'
    # shellcheck disable=SC2250 # deliberately unbraced/unquoted: word-splits PATH on the IFS=':' set above to scan each entry
    for dir in $PATH; do
        [[ -n "${dir}" ]] || continue
        cand="${dir}/br"
        [[ -x "${cand}" ]] && [[ -f "${cand}" ]] || continue
        # shellcheck disable=SC2312 # readlink failure just falls through to "not self"; no return value worth capturing separately
        [[ "$(readlink -f "${cand}")" = "${SELF}" ]] && continue
        printf '%s\n' "${cand}"
        return 0
    done
    return 1
}

# shellcheck disable=SC2310 # failure is handled explicitly by the || block below (exit 1); set -e need not apply here
REAL_BR=$(find_real_br) || {
    echo "br-wrapper: error: real 'br' binary not found in PATH" >&2
    echo "br-wrapper: install it first: https://github.com/Dicklesworthstone/beads_rust" >&2
    exit 1
}

# --- Shared helpers -----------------------------------------------------------

require_work_tree() {
    if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        echo "br-wrapper: error: not inside a git repository" >&2
        exit 1
    fi
}

project_name() {
    # Prefer the origin remote's repo name; fall back to the directory name.
    # For owner-qualified names (avoids fork/name collisions), see README.
    local url
    if url=$(git remote get-url origin 2>/dev/null); then
        basename "${url}" .git
    else
        # shellcheck disable=SC2312 # git rev-parse failure here would exit the script under set -e; no separate capture needed
        basename "$(git rev-parse --show-toplevel)"
    fi
}

sync_repo_pull() {
    # --ff-only: fail loudly on divergence rather than creating merge commits.
    git -C "${SYNC_REPO}" pull --ff-only
}

# Record (or update) this machine's absolute path for a project name in the
# index file. Idempotent: re-pushing the same project replaces its line
# rather than duplicating it; a renamed/moved project's entry is updated in
# place. Format: one "name<TAB>absolute-path" pair per line.
#
# Every step checks its own exit status and returns 1 on failure rather than
# relying on `set -e`: this is called from push_one(), which cmd_push_all()
# runs inside an `if ( subshell )` condition where bash disables `-e`
# enforcement — an unchecked mktemp/awk/mv failure there would be silently
# swallowed and the push would report success with a stale/missing index.
record_project_path() {
    local name="$1" path="$2" tmp
    if ! tmp=$(mktemp "${SYNC_REPO}/.project-paths.XXXXXX"); then
        echo "br-wrapper: error: could not create temp file in ${SYNC_REPO} for project-path index" >&2
        return 1
    fi
    if [[ -f "${PROJECT_PATHS_FILE}" ]]; then
        # awk (not grep -v with an interpolated pattern) so a project name
        # containing regex metacharacters (e.g. a dot) is matched literally.
        if ! awk -F'\t' -v n="${name}" '$1 != n' "${PROJECT_PATHS_FILE}" > "${tmp}"; then
            rm -f "${tmp}"
            echo "br-wrapper: error: could not rewrite project-path index" >&2
            return 1
        fi
    fi
    if ! printf '%s\t%s\n' "${name}" "${path}" >> "${tmp}"; then
        rm -f "${tmp}"
        echo "br-wrapper: error: could not append to project-path index temp file" >&2
        return 1
    fi
    if ! mv "${tmp}" "${PROJECT_PATHS_FILE}"; then
        rm -f "${tmp}"
        echo "br-wrapper: error: could not move project-path index into place at ${PROJECT_PATHS_FILE}" >&2
        return 1
    fi
}

# Look up a project's recorded absolute path. Prints the path and returns 0
# if found, otherwise prints nothing and returns 1.
lookup_project_path() {
    local name="$1"
    [[ -f "${PROJECT_PATHS_FILE}" ]] || return 1
    awk -F'\t' -v n="${name}" '$1 == n { print $2; found=1 } END { exit !found }' "${PROJECT_PATHS_FILE}"
}

# --- Command: init ------------------------------------------------------------

cmd_init() {
    require_work_tree
    local repo_root gitignore had_gitignore exclude_file
    repo_root=$(git rev-parse --show-toplevel)
    cd "${repo_root}"

    # Snapshot .gitignore. The Rust br claims to only touch .beads/, but the
    # original Go bd modified the repo .gitignore on init; guard either way.
    # Empirically verified (tests/run.sh, real br v0.2.16): `br init` does
    # NOT create or modify a top-level .gitignore at all — it only creates
    # .beads/ (which contains its own internal .beads/.gitignore). This
    # snapshot/revert logic is therefore currently a no-op safety net, kept
    # in case a future br version changes that behavior.
    # NOTE: _snapshot is deliberately not `local` — the EXIT trap fires after
    # this function returns, when locals are already out of scope.
    gitignore="${repo_root}/.gitignore"
    had_gitignore=0
    _snapshot=""
    if [[ -f "${gitignore}" ]]; then
        had_gitignore=1
        _snapshot=$(mktemp)
        trap 'rm -f "${_snapshot:-}"' EXIT
        cp "${gitignore}" "${_snapshot}"
    fi

    "${REAL_BR}" init "$@"

    if [[ "${had_gitignore}" -eq 1 ]]; then
        if ! cmp -s "${_snapshot}" "${gitignore}" 2>/dev/null; then
            cp "${_snapshot}" "${gitignore}"
            echo "br-wrapper: reverted .gitignore changes made by 'br init'"
        fi
    elif [[ -f "${gitignore}" ]]; then
        rm "${gitignore}"
        echo "br-wrapper: removed .gitignore created by 'br init'"
    fi

    # --git-path resolves correctly in worktrees/submodules.
    exclude_file=$(git rev-parse --git-path info/exclude)
    mkdir -p "$(dirname "${exclude_file}")"
    if ! grep -qxF '.beads/' "${exclude_file}" 2>/dev/null; then
        # shellcheck disable=SC2312 # tail failure here is inconsequential: worst case is an extra blank line before the appended entry
        if [[ -s "${exclude_file}" ]] && [[ "$(tail -c 1 "${exclude_file}")" != "" ]]; then
            printf '\n' >> "${exclude_file}"
        fi
        printf '.beads/\n' >> "${exclude_file}"
        echo "br-wrapper: added '.beads/' to ${exclude_file}"
    fi
}

# --- Command: push ------------------------------------------------------------

# Core single-project push, run from inside the target project's work tree
# (cwd is already the project root; BEADS_DIR is confirmed present). Does NOT
# pull the sync repo itself — callers are responsible for that, so
# `push --all` can pull once up front instead of once per project. Returns 0
# on success (including the no-op "nothing to commit" case) and 1 on failure,
# rather than exiting the whole process, so `push --all` can keep going after
# one project's push fails.
push_one() {
    local name project_dir copied=0 f
    name=$(project_name)
    project_dir="${PROJECTS_DIR}/${name}"

    if ! "${REAL_BR}" sync --flush-only; then
        echo "br-wrapper: error: 'br sync --flush-only' failed for ${name:-this project}" >&2
        return 1
    fi

    # NOTE: mkdir/cp exit statuses are checked explicitly rather than relying
    # on `set -e` to abort on failure. push_one() is invoked from
    # cmd_push_all() as `if ( cd "${path}" && push_one ); then ...` — and
    # bash disables `-e` enforcement inside a subshell that is itself used
    # directly as an `if`/`&&`/`||` condition, so a failing cp there would
    # otherwise be silently ignored instead of being caught below.
    if ! mkdir -p "${project_dir}"; then
        echo "br-wrapper: error: could not create ${project_dir}" >&2
        return 1
    fi
    for f in "${TRACKED_FILES[@]}"; do
        if [[ -f "${BEADS_DIR}/${f}" ]]; then
            if cp "${BEADS_DIR}/${f}" "${project_dir}/${f}"; then
                copied=$((copied + 1))
            else
                echo "br-wrapper: error: failed to copy ${f} to ${project_dir}" >&2
                return 1
            fi
        fi
    done
    if [[ "${copied}" -eq 0 ]]; then
        echo "br-wrapper: error: no trackable beads files found" >&2
        return 1
    fi

    # Capture the toplevel into a checked variable first: on the --all path
    # this function runs inside an `if ( subshell )` where set -e is inert,
    # so an unchecked `$(git rev-parse ...)` failure would silently pass an
    # empty path to record_project_path instead of aborting.
    local toplevel
    if ! toplevel=$(git rev-parse --show-toplevel); then
        echo "br-wrapper: error: could not resolve project toplevel for ${name}" >&2
        return 1
    fi
    # shellcheck disable=SC2310 # failure is handled explicitly by this if/return; set -e need not apply here
    if ! record_project_path "${name}" "${toplevel}"; then
        echo "br-wrapper: error: failed to record project path for ${name}" >&2
        return 1
    fi

    # Scope the add to this project only — local edits to the wrapper/scripts
    # should be committed deliberately, not swept up in a sync.
    if ! git -C "${SYNC_REPO}" add "projects/${name}"; then
        echo "br-wrapper: error: 'git add' failed for ${name}" >&2
        return 1
    fi
    if git -C "${SYNC_REPO}" diff --cached --quiet; then
        echo "No beads changes to commit for ${name}."
        return 0
    fi
    if ! git -C "${SYNC_REPO}" commit -m "sync beads: ${name}"; then
        echo "br-wrapper: error: 'git commit' failed for ${name}" >&2
        return 1
    fi
    if ! git -C "${SYNC_REPO}" push; then
        echo "br-wrapper: error: 'git push' failed for ${name}" >&2
        return 1
    fi
    # shellcheck disable=SC2312 # git rev-parse failure here would exit the script under set -e; no separate capture needed
    echo "Beads pushed for ${name} -> $(git -C "${SYNC_REPO}" rev-parse --short HEAD)"
}

cmd_push() {
    if [[ "${1:-}" == "--all" ]]; then
        cmd_push_all
        return $?
    fi

    # Reject unknown options loudly rather than silently ignoring them and
    # running a single-project push the user didn't ask for (e.g. a typo'd
    # `br push --al` must not quietly degrade to `br push`).
    if [[ "${1:-}" == -* ]]; then
        echo "br-wrapper: error: unknown push option '${1}' (did you mean --all?)" >&2
        exit 1
    fi

    require_work_tree
    # shellcheck disable=SC2312 # git rev-parse failure here would exit the script under set -e; no separate capture needed
    cd "$(git rev-parse --show-toplevel)"

    if [[ ! -d "${BEADS_DIR}" ]]; then
        echo "br-wrapper: error: no ${BEADS_DIR} here (run 'br init' first)" >&2
        exit 1
    fi

    sync_repo_pull
    # shellcheck disable=SC2310 # failure is handled explicitly by the || block below (exit 1); set -e need not apply here
    push_one || exit 1
}

# `br push --all`: pull the sync repo once, then walk every projects/<name>/
# directory, look up its recorded absolute path, and push from there. A
# project with no index entry, or whose recorded path no longer exists / is
# no longer a git repo, is skipped with a warning rather than failing the
# whole run. Exit 0 iff every known project pushed cleanly (no-ops count as
# clean); nonzero if any known project's push actually failed.
cmd_push_all() {
    # No require_work_tree here, deliberately: unlike the single-project
    # commands, --all operates on recorded paths and is runnable from
    # anywhere, including outside any git repo.
    sync_repo_pull

    if [[ ! -d "${PROJECTS_DIR}" ]]; then
        echo "br-wrapper: no projects/ directory yet; nothing to push."
        return 0
    fi

    local dir name path failed=0 pushed=0 skipped=0
    for dir in "${PROJECTS_DIR}"/*/; do
        [[ -d "${dir}" ]] || continue
        name=$(basename "${dir}")

        # shellcheck disable=SC2310 # failure is handled explicitly below (skip + warn); set -e need not apply here
        if ! path=$(lookup_project_path "${name}"); then
            echo "br-wrapper: warning: skipping '${name}' (no recorded path; run 'br push' from it once on this machine)" >&2
            skipped=$((skipped + 1))
            continue
        fi
        if [[ ! -d "${path}" ]]; then
            echo "br-wrapper: warning: skipping '${name}' (recorded path no longer exists: ${path})" >&2
            skipped=$((skipped + 1))
            continue
        fi
        if ! git -C "${path}" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
            echo "br-wrapper: warning: skipping '${name}' (recorded path is not a git repo: ${path})" >&2
            skipped=$((skipped + 1))
            continue
        fi
        if [[ ! -d "${path}/${BEADS_DIR}" ]]; then
            echo "br-wrapper: warning: skipping '${name}' (no ${BEADS_DIR} at recorded path: ${path})" >&2
            skipped=$((skipped + 1))
            continue
        fi

        echo "br-wrapper: pushing '${name}' (${path})..."
        # shellcheck disable=SC2310 # failure is handled explicitly below (warn + aggregate); set -e need not apply here
        if ( cd "${path}" && push_one ); then
            pushed=$((pushed + 1))
        else
            echo "br-wrapper: warning: push failed for '${name}'" >&2
            failed=$((failed + 1))
        fi
    done

    echo "br-wrapper: push --all summary: ${pushed} pushed, ${skipped} skipped, ${failed} failed"
    [[ "${failed}" -eq 0 ]]
}

# --- Command: restore ---------------------------------------------------------

cmd_restore() {
    require_work_tree
    # shellcheck disable=SC2312 # git rev-parse failure here would exit the script under set -e; no separate capture needed
    cd "$(git rev-parse --show-toplevel)"

    local name project_dir restored=0 f
    name=$(project_name)
    project_dir="${PROJECTS_DIR}/${name}"

    sync_repo_pull

    if [[ ! -d "${project_dir}" ]]; then
        echo "br-wrapper: error: no 'projects/${name}' in sync repo" >&2
        exit 1
    fi

    # No workspace yet (fresh clone / new machine): run the augmented init.
    if [[ ! -d "${BEADS_DIR}" ]]; then
        cmd_init
    fi

    for f in "${TRACKED_FILES[@]}"; do
        if [[ -f "${project_dir}/${f}" ]]; then
            cp "${project_dir}/${f}" "${BEADS_DIR}/${f}"
            restored=$((restored + 1))
        fi
    done
    if [[ "${restored}" -eq 0 ]]; then
        echo "br-wrapper: error: nothing restorable in projects/${name}" >&2
        exit 1
    fi

    "${REAL_BR}" sync --import-only
    echo "Restored ${restored} file(s) for ${name} and imported into the database."
}

# --- Dispatch -------------------------------------------------------------------

case "${1:-}" in
    init)    shift; cmd_init "$@" ;;
    push)    shift; cmd_push "$@" ;;
    restore) shift; cmd_restore "$@" ;;
    *)       exec "${REAL_BR}" "$@" ;;
esac
